    <Color x:Key="Hud_BaseColor">#50000510</Color>
    <SolidColorBrush x:Key="Hud_BaseBrush" Color="{StaticResource Hud_BaseColor}"/>

    <SolidColorBrush x:Key="Hud_BorderBrush_On" Color="#B000F0FF"/>

    <SolidColorBrush x:Key="Hud_BorderBrush_Disabled" Color="#80608090"/>

    <SolidColorBrush x:Key="Hud_TextBrush" Color="#E0E0E0"/>

    <SolidColorBrush x:Key="Hud_TextBrush_Disabled" Color="#D0D0D0"/>

    <SolidColorBrush x:Key="Hud_ArrowBrush_Disabled" Color="#A0A0A0"/>

    <SolidColorBrush x:Key="Hud_HighlightBrush" Color="#4000F0FF"/>

    <Style x:Key="HudComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="{Binding HorizontalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
        <Setter Property="VerticalContentAlignment" Value="{Binding VerticalContentAlignment, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="5,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Hud_HighlightBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Hud_BorderBrush_On}"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    <Style x:Key="NormalTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Height" Value="25"/>
        <Setter Property="Margin" Value="{DynamicResource UIELEMENT_MARGIN}"/>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="{DynamicResource black_color}" />
        <Setter Property="FontFamily" Value="Malgun Gothic" />
        <Setter Property="FontSize" Value="10pt" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontStyle" Value="Normal" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="bdButton"  BorderThickness="0" Margin="-1" Background="{TemplateBinding Background}" ClipToBounds="True" TextBlock.TextAlignment="Center">
                        <Grid>
                            <Border x:Name="bdInnerShadowU" BorderThickness="0,1,0,0" BorderBrush="#1d2026" />
                            <Border x:Name="bdInnerShadowD" BorderThickness="0,0,0,1" BorderBrush="#707781" Opacity="0.5" />
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" BorderThickness="0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"  Style="{StaticResource SVStyle_TextBox}"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_ContentHost" Property="Opacity" Value="1" />
                            <Setter Property="Background" Value="{DynamicResource MLAH_COLOR_POPUP_DLG_BG_Brush}" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="True"></Condition>
                                <Condition Property="Tag" Value="SUT"></Condition>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter Property="Background" Value="{DynamicResource black_color}" />
                                <Setter TargetName="bdButton" Property="BorderThickness" Value="1" />
                                <Setter TargetName="bdButton" Property="BorderBrush" Value="{DynamicResource yellow_color}" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="ToolTipService.IsEnabled" Value="True" />
                            </MultiTrigger.Setters>
                        </MultiTrigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource black_color}" />
                            <Setter TargetName="bdButton" Property="BorderThickness" Value="1" />
                            <Setter TargetName="bdButton" Property="BorderBrush" Value="{DynamicResource yellow_color}" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="ToolTipService.IsEnabled" Value="True" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="Background" Value="{DynamicResource black_color}" />
                            <Setter TargetName="bdButton" Property="BorderThickness" Value="1" />
                            <Setter TargetName="bdButton" Property="BorderBrush" Value="{DynamicResource yellow_color}" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="ToolTipService.IsEnabled" Value="True" />
                        </Trigger>
                        <Trigger Property="Button.IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource nc_on_color}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bdButton" Property="BorderBrush" Value="Transparent" />
                            <Setter TargetName="bdButton" Property="BorderThickness" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


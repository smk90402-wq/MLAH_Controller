    <Style x:Key="BlinkingRedTextBlock" TargetType="TextBlock">
        <!-- 처음 색상 지정 -->
        <Setter Property="Foreground" Value="Red"/>
        <Style.Triggers>
            <!-- TextBlock이 로드되었을 때에 애니메이션 시작 -->
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <!-- 빨간색과 투명색을 왔다갔다하며 깜빡이는 효과 -->
                        <ColorAnimation 
                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                            From="Red" To="Transparent" 
                            Duration="0:0:0.5" 
                            AutoReverse="True" 
                            RepeatBehavior="Forever"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>



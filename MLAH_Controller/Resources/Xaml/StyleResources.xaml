    <Style x:Key="NormalCheckBoxStyle" TargetType="{x:Type CheckBox}" >
        <Setter Property="FontFamily" Value="Malgun Gothic" />
        <Setter Property="FontSize" Value="10pt" />
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_WHITE_Brush}"/>
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <BulletDecorator Background="Transparent">
                        <BulletDecorator.Bullet>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Grid >
                                        <Rectangle x:Name="toff" Width="14" Height="14" Fill="{DynamicResource black_color}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        </Rectangle>
                                        <Border Width="14" Height="1" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="1" BorderBrush="#1d2026"/>
                                        <Polyline x:Name="ton" Width="6" Height="5" Margin="0,1,0,0" Points="0,1 2,5 6,0"  Stroke="{DynamicResource MLAH_COLOR_SELECTABLE_TEXT_Brush}" StrokeThickness="1.5" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Rectangle x:Name="tstroke" Width="14" Height="14" Stroke="{DynamicResource yellow_color}" StrokeThickness="1.5" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                    <ContentPresenter x:Name="tcp" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </BulletDecorator.Bullet>
                    </BulletDecorator>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="True">
                            <Setter TargetName="tcp" Property="TextElement.FontFamily" Value="{Binding Path=(TextElement.FontFamily), RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="tcp" Property="TextElement.FontSize" Value="{Binding Path=(TextElement.FontSize), RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="tcp" Property="TextElement.Foreground" Value="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="true">
                            <Setter TargetName="ton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tstroke" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NormalRadioButtonStyle" TargetType="{x:Type RadioButton}" >
        <Setter Property="FontFamily" Value="Malgun Gothic" />
        <Setter Property="FontSize" Value="10pt" />
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_WHITE_Brush}"/>
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="{DynamicResource gray_color}" />
        <Setter Property="Margin" Value="{DynamicResource UIELEMENT_MARGIN_VERTICAL_SHORT}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <BulletDecorator Background="Transparent">
                        <BulletDecorator.Bullet>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Grid>
                                        <Ellipse x:Name="toff" Width="14" Height="14" Fill="{DynamicResource black_color}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#1d2026" Direction="-90" BlurRadius="0" ShadowDepth="1" />
                                            </Ellipse.Effect>
                                        </Ellipse>
                                        <Ellipse x:Name="ton" Width="8" Height="8" Fill="{DynamicResource white_color}" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Ellipse x:Name="tstroke" Width="14" Height="14" Stroke="{DynamicResource yellow_color}" StrokeThickness="1.5" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock x:Name="tcp" Text="{TemplateBinding Property=Content}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </BulletDecorator.Bullet>
                    </BulletDecorator>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="toff" Property="Opacity" Value="0.2"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="true">
                            <Setter TargetName="ton" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="tcp" Property="TextBlock.Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tstroke" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--Tab 스크롤 Repeat 버튼 스타일-->
    <Style x:Key="TabScrollerRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="Background" Value="{DynamicResource lineA_color}" />
        <Setter Property="BorderBrush" Value="Transparent" />

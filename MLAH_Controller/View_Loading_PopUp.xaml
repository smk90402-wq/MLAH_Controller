<Window x:Class="MLAH_Controller.View_Loading_PopUp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
      mc:Ignorable="d" 
      Height="100" Width="200"
      WindowStyle="None" 
      IsHitTestVisible="True"
      MouseDown="ViewModel_DialogBase_MouseDown" 
      ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True" IsVisibleChanged="Window_IsVisibleChanged">
    <Window.Background>
        <StaticResource ResourceKey="DefaultBg_Brush"/>
    </Window.Background>
    <Grid>
        <dx:WaitIndicator DeferedVisibility="True" Content="TestText">
            <dx:WaitIndicator.ContentTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Please Wait" FontSize="20"/>
                        <TextBlock Text="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </dx:WaitIndicator.ContentTemplate>
        </dx:WaitIndicator>

    </Grid>
</Window>

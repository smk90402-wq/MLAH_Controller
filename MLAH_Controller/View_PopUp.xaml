<Window x:Class="MLAH_Controller.View_PopUp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Height="200" Width="400"
      WindowStyle="None" 
      AllowsTransparency="True"
      Background="Transparent"
      IsHitTestVisible="True"
      MouseDown="ViewModel_DialogBase_MouseDown" 
      ResizeMode="NoResize" 
      WindowStartupLocation="CenterScreen" 
      Topmost="True" 
      IsVisibleChanged="Window_IsVisibleChanged">

    <Border Background="#E6050A15" 
            BorderBrush="#8000F0FF" 
            BorderThickness="1" 
            CornerRadius="6" 
            Margin="10">

        <Border.Effect>
            <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2000F0FF" Padding="0,8" CornerRadius="5,5,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Rectangle Width="3" Height="14" Fill="#00F0FF" Margin="0,0,8,0"/>

                    <TextBlock Name="Description" 
                               TextAlignment="Center" 
                               FontSize="14" 
                               FontWeight="ExtraBold" 
                               Foreground="#00F0FF" 
                               FontFamily="Malgun Gothic"
                               x:FieldModifier="public">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00F0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Rectangle Width="3" Height="14" Fill="#00F0FF" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Name="Reason" 
                       Grid.Row="1" 
                       Foreground="White" 
                       TextAlignment="Center" 
                       VerticalAlignment="Center" 
                       TextWrapping="Wrap" 
                       Margin="15,10,15,10" 
                       FontSize="13" 
                       x:FieldModifier="public" />

            <Button x:Name="ConfirmButton" 
                    Grid.Row="2" 
                    Width="160" 
                    Height="30" 
                    Margin="0,0,0,12" 
                    Click="ConfirmEvent" 
                    Style="{DynamicResource HudButtonStyle}"/>
        </Grid>
    </Border>
</Window>
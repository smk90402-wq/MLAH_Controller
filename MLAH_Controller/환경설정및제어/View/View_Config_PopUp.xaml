        <GroupBox Grid.Column="9" Grid.Row="1" Header="무인기 모의 3 SW" Foreground="White" BorderThickness="0.5" BorderBrush="White" Margin="1,1,1,1">
            <Grid Grid.Column="0" Background="{StaticResource MLAH_COLOR_BG_Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="5"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Host" Foreground="White"/>
                <TextBlock Grid.Row="1" Text="사용자" Foreground="White"/>
                <TextBlock Grid.Row="2" Text="비밀번호" Foreground="White"/>
                <TextBlock Grid.Row="3" Text="실행파일 경로" Foreground="White"/>

                <TextBox Grid.Column="2" Grid.Row="0" Width="140" Text="{Binding UAVSim3IP, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                <TextBox Grid.Column="2" Grid.Row="1" Width="140" Text="{Binding DroneSituationUser, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                <TextBox Grid.Column="2" Grid.Row="2" Width="140" Text="{Binding DroneSituationPw, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                <TextBox Grid.Column="2" Grid.Row="3" Width="140" Text="{Binding DroneSituationExecPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox_NoViewBox}" IsEnabled="{Binding EditEnable}"/>

                <Button Grid.Column="0" Grid.Row="6" Width="80" Content="SW 실행" Style="{StaticResource HudButtonStyle}" Margin="{StaticResource UIELEMENT_MARGIN}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="PreviewMouseDown">
                            <i:InvokeCommandAction Command="{Binding UAV3ExecCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>

                <Button Grid.Column="2" Grid.Row="6" Width="80" Content="SW 종료" Style="{StaticResource HudButtonStyle}" Margin="{StaticResource UIELEMENT_MARGIN}" HorizontalAlignment="Left">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="PreviewMouseDown">
                            <i:InvokeCommandAction Command="{Binding UAV3QuitCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>

            </Grid>
        </GroupBox>

        <GroupBox Grid.Column="9" Grid.Row="0" Header="전장상황 모의 SW (Debug)" Foreground="White" BorderThickness="0.5" BorderBrush="White" Margin="1,1,1,1">
            <Grid Grid.Column="0" Background="{StaticResource MLAH_COLOR_BG_Brush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="5"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>

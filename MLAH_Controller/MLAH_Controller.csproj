	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Exec Command="REM --- Config.ini 스마트 복사 ---&#xD;&#xA;REM 파일이 없으면 복사, 있으면 필수 섹션([IPSet]) 확인 후 누락 시만 복사&#xD;&#xA;if not exist &quot;$(TargetDir)Config.ini&quot; (&#xD;&#xA;    copy /y &quot;$(ProjectDir)Resources\Config.ini&quot; &quot;$(TargetDir)Config.ini&quot;&#xD;&#xA;) else (&#xD;&#xA;    findstr /c:&quot;[IPSet]&quot; &quot;$(TargetDir)Config.ini&quot; &gt;nul 2&gt;&amp;1&#xD;&#xA;    if errorlevel 1 (&#xD;&#xA;        copy /y &quot;$(ProjectDir)Resources\Config.ini&quot; &quot;$(TargetDir)Config.ini&quot;&#xD;&#xA;    )&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;REM --- 단일 파일 복사 (Xcopy) ---&#xD;&#xA;REM PsExec.exe와 .proto 파일을 출력 폴더로 복사합니다.&#xD;&#xA;xcopy /y &quot;$(ProjectDir)Resources\srtm_62_05.tif&quot; &quot;$(TargetDir)\&quot;&#xD;&#xA;xcopy /y &quot;$(ProjectDir)Resources\PsExec.exe&quot; &quot;$(TargetDir)\&quot;&#xD;&#xA;REM proto 파일은 MLAH_Proto 프로젝트에서 자동 복사됨&#xD;&#xA;&#xD;&#xA;REM --- 폴더 복사 (Xcopy) ---&#xD;&#xA;REM ScenarioFiles 폴더를 출력 폴더에 복사합니다.&#xD;&#xA;REM /i 옵션은 대상이 폴더가 없는 경우 새로 만들도록 합니다.&#xD;&#xA;xcopy /y /i /e &quot;$(ProjectDir)Resources\ScenarioFiles&quot; &quot;$(TargetDir)ScenarioFiles\&quot;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;REM --- 불필요한 언어 리소스 폴더 삭제 ---&#xD;&#xA;REM 'ko' 폴더를 제외한 모든 언어 리소스 폴더(*.resources.dll을 포함하는)를 삭제합니다.&#xD;&#xA;if exist &quot;$(TargetDir)&quot; (&#xD;&#xA;    pushd &quot;$(TargetDir)&quot;&#xD;&#xA;    for /d %25%25i in (*) do (&#xD;&#xA;        if exist &quot;%25%25i\*.resources.dll&quot; (&#xD;&#xA;            if /I not &quot;%25%25i&quot;==&quot;ko&quot; (&#xD;&#xA;                rmdir /s /q &quot;%25%25i&quot;&#xD;&#xA;            )&#xD;&#xA;        )&#xD;&#xA;    )&#xD;&#xA;    popd&#xD;&#xA;)&#xD;&#xA;" />
	</Target>

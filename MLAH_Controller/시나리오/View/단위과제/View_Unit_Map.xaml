<UserControl x:Class="MLAH_Controller.View_Unit_Map"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:ViewModel_Unit_Map, IsDesignTimeCreatable=True}"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"      
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxm="http://schemas.devexpress.com/winfx/2008/xaml/map"
        xmlns:core="clr-namespace:Microsoft.Xaml.Behaviors.Core;assembly=Microsoft.Xaml.Behaviors"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"
        PreviewKeyDown="UserControl_PreviewKeyDown">
    <!--<UserControl.DataContext>
        <Binding Source="{x:Static local:ViewModel_Unit_Map.SingletonInstance}"/>
    </UserControl.DataContext>-->
    <UserControl.Resources>
        <DataTemplate x:Key="ElementTemplate" DataType="{x:Type local:UnitMapObjectInfo}">
            <Grid>
                <!--CacheMode="BitmapCache"-->
                <Border MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" >
                    <Image Source="{Binding imagesource}" Width="40" Height="40" MouseLeftButtonDown="Element_MouseLeftButtonDown">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <RotateTransform CenterX="20" CenterY="20">
                                    <RotateTransform.Angle>
                                        <MultiBinding Converter="{StaticResource ConditionalRotationConverter }">
                                            <Binding Path="Heading" />
                                            <Binding Path="Type" />
                                        </MultiBinding>
                                    </RotateTransform.Angle>
                                </RotateTransform>
                                <TranslateTransform X="-20" Y="-20" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                </Border>
                <TextBlock Text="{Binding ID}"
               Foreground="Black"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,20"
               Visibility="{Binding Source={x:Static local:ViewModel_Unit_Map.SingletonInstance}, Path=FilterEntityID, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="RTBSymbolTemplate">
            <Image Width="30" Height="30" Source="{StaticResource RTB}">
                <Image.RenderTransform>
                    <TranslateTransform X="-15" Y="-15" />
                </Image.RenderTransform>
            </Image>
        </DataTemplate>

        <DataTemplate x:Key="UnitToolTipTemplate" DataType="{x:Type local:UnitMapObjectInfo}">
            <Border CornerRadius="5" BorderThickness="2" Padding="10">
                <Border.Background>
                    <SolidColorBrush Color="#CC000000"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#FF00FFFF"/>
                </Border.BorderBrush>

                <!--<Border.Effect>
                    <DropShadowEffect Color="#FF00FFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                </Border.Effect>-->

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,5">
                        <TextBlock Text="UNIT ID : " Foreground="#FFAAAAAA" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ID}" Foreground="White" FontSize="14" FontWeight="ExtraBold" Margin="5,0,0,0"/>
                    </StackPanel>

                    <Separator Grid.Row="1" Background="#55FFFFFF" Margin="0,0,0,5"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TYPE" Foreground="#FF888888" FontSize="10" Margin="0,0,10,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TypeString}" Foreground="#FF00FF00" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="PLATFORM" Foreground="#FF888888" FontSize="10" Margin="0,2,10,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PlatformString}" Foreground="White"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>


    </UserControl.Resources>

    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.ColumnSpan="2">
            <dxm:MapControl x:Name="mapControl" CenterPoint="38.128774, 127.318005" FlowDirection="LeftToRight" IsManipulationEnabled="True" EnableRotation="False"  
                            MaxZoomLevel="15" MinZoomLevel="8"
                            MouseDown="MapControl_MouseButtonDown" 
                            MouseMove="MapControl_MouseMove" 
                            RenderOptions.BitmapScalingMode="LowQuality"
                            SizeChanged="mapControl_SizeChanged"
                            UseSprings="False"
                            ZoomLevel="{Binding CurrentZoomLevel, Mode=TwoWay}"
                            
                            >
                <!--RenderOptions.BitmapScalingMode="LowQuality"-->
                <!-- MouseWheel="mapControl_MouseWheel"-->
                <dxm:MapControl.Measurements>
                    <dxm:Measurements DistanceUnits="{x:Static dxm:MeasureUnit.Meter}" AreaUnits="{x:Static dxm:AreaMeasurementUnit.SquareMeter}">
                        <dxm:Measurements.ToolbarOptions>
                            <dxm:MeasurementToolbarOptions Visible="True" VerticalAlignment="Bottom"/>
                        </dxm:Measurements.ToolbarOptions>
                    </dxm:Measurements>
                </dxm:MapControl.Measurements>

                <!--<dxm:MapControl.MapEditor>
                    <dxm:MapEditor MapItemEdited="MapEditor_MapItemEdited" ActiveLayer="{Binding ElementName=FlightAreaPolygonEditLayer}" >
                        <dxm:MapEditor.EditorPanelOptions >
                            <dxm:MapEditorPanelOptions Visible="False"/>
                        </dxm:MapEditor.EditorPanelOptions>
                    </dxm:MapEditor>
                </dxm:MapControl.MapEditor>-->

                <dxm:MapControl.MapEditor>
                    <dxm:MapEditor MapItemEdited="MapEditor_MapItemEdited">

                        <dxm:MapEditor.EditorPanelOptions>
                            <dxm:MapEditorPanelOptions Visible="False"/>
                        </dxm:MapEditor.EditorPanelOptions>

                        <dxm:MapEditor.ActiveLayer>
                            <MultiBinding Converter="{StaticResource EditLayerConverter}">
                                <Binding Path="CurrentEditLayer" />
                                <Binding ElementName="INITMissionPolygonEditLayer"/>
                                <Binding ElementName="FlightAreaPolygonEditLayer"/>
                                <Binding ElementName="ProhibitedAreaPolygonEditLayer"/>
                                <Binding ElementName="TempINITMissionPolygonEditLayer"/>
                            </MultiBinding>
                        </dxm:MapEditor.ActiveLayer>

                    </dxm:MapEditor>
                </dxm:MapControl.MapEditor>





                <dxm:MapControl.Legends>
                    <dxm:ColorListLegend Header="">
                        <dxm:ColorListLegend.CustomItems>
                            <dxm:ColorLegendItem Text="협업기저임무" Color="MediumPurple"/>
                            <dxm:ColorLegendItem Text="비행가능구역" Color="SkyBlue"/>
                            <dxm:ColorLegendItem Text="비행금지구역" Color="IndianRed"/>
                        </dxm:ColorListLegend.CustomItems>
                    </dxm:ColorListLegend>

                </dxm:MapControl.Legends>

                <dxm:MapControl.Layers>
                    <!--<dxm:ImageLayer>
                        <dxm:ImageTileDataProvider>
                            <dxm:ImageTileDataProvider.TileSource>
                                <local:LocalTileSource/>
                            </dxm:ImageTileDataProvider.TileSource>
                        </dxm:ImageTileDataProvider>
                    </dxm:ImageLayer>-->

                    <dxm:ImageLayer>
                        <dxm:AzureMapDataProvider x:Name="azureProvider" Tileset="Imagery">
                        </dxm:AzureMapDataProvider>
                    </dxm:ImageLayer>

           

                    <dxm:VectorLayer x:Name="UnrealLandScapeLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding UnrealLandScapeList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Fill="Transparent" Stroke="Purple" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

       

                    <dxm:VectorLayer x:Name="FocusSquareLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding FocusSquareItems}" />
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="FocusHeadingLineLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding FocusHeadingLineList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings>
                                </dxm:MapPolylineSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="FourCornerLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding FourCornerItems}" />
                    </dxm:VectorLayer>

                    

                    <dxm:VectorLayer x:Name="TempINITMissionPolygonLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TempINITMissionPolygonList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Fill="Red" Stroke="Black" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="PreINITMissionPolygonLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding PreINITMissionPolygonList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Fill="Red" Stroke="Black" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>


                    <dxm:VectorLayer x:Name="TempINITMissionPolygonEditLayer" AllowEditItems="{Binding IsTempINITMissionPolygonEditMode}" EnableSelection="True">
                        <dxm:MapItemStorage x:Name="TempINITMissionPolygonEditStorage"/>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="TempINITMissionPolygonLineLayer" ShapeFill="Red" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TempINITMissionPolygonLineList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapLineSettings Fill="Red" Stroke="Black" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Points" />
                                <!--<dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>-->
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="LAHStaticLayer"
                 EnableSelection="False"
                 EnableHighlighting="False"
                 ToolTipEnabled="False"
>
                        <!--<dxm:VectorLayer.CacheMode>
                            <BitmapCache RenderAtScale="1"/>
                        </dxm:VectorLayer.CacheMode>-->

                        <dxm:ListSourceDataAdapter DataSource="{Binding LAHStaticLineList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <!--<dxm:VectorLayer x:Name="LAHPulseLayer" 
                 EnableSelection="False" 
                 EnableHighlighting="False" 
                 ToolTipEnabled="False">

                        --><!--<dxm:VectorLayer.Effect>
                            <DropShadowEffect Color="#FF4500" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                        </dxm:VectorLayer.Effect>--><!--

                        <dxm:ListSourceDataAdapter DataSource="{Binding LAHPulseLineList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>-->

                    <dxm:VectorLayer x:Name="LAHWaypointMarkerLayer"
                 EnableSelection="False"
                 EnableHighlighting="False"
>
                        <dxm:ListSourceDataAdapter DataSource="{Binding LAHWpMarkerList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings>
                                    <dxm:MapCustomElementSettings.ContentTemplate>
                                        <DataTemplate>
                                            <Canvas Width="0" Height="0">

                                                <Grid Canvas.Left="-6" Canvas.Top="-6" Width="12" Height="12">
                                                    <Grid.RenderTransform>
                                                        <RotateTransform Angle="{Binding Heading}" CenterX="6" CenterY="6"/>
                                                    </Grid.RenderTransform>

                                                    <Path Data="M 5,0 L 10,10 L 5,7.5 L 0,10 Z" 
                                                        Fill="#FF4500" 
                                                        Stroke="Black" 
                                                        StrokeThickness="1" 
                                                        Stretch="Fill"/>        
                                                </Grid>

                                                <Grid Canvas.Left="-50" Canvas.Top="15" Width="100">

                                                    <TextBlock Text="{Binding TagString}"
                                           FontSize="10" FontWeight="ExtraBold" Foreground="White"
                                           TextAlignment="Center" HorizontalAlignment="Center">
                                                        <!--<TextBlock.Effect>
                                                            <BlurEffect Radius="4"/>
                                                        </TextBlock.Effect>-->
                                                    </TextBlock>

                                                    

                                                    <TextBlock Text="{Binding TagString}"
                                           FontSize="10" FontWeight="Bold" Foreground="#111111" 
                                           TextAlignment="Center" HorizontalAlignment="Center"/>
                                                </Grid>

                                            </Canvas>
                                        </DataTemplate>
                                    </dxm:MapCustomElementSettings.ContentTemplate>
                                </dxm:MapCustomElementSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>

                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="UAVWaypointLayer" ShapeStroke="#1E90FF" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False"
>
                        <dxm:ListSourceDataAdapter DataSource="{Binding UAVWapointList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="TextTestWapointLayer" ShapeStroke="Red" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TextTestWapointList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>


                    <dxm:VectorLayer x:Name="UAVWaypointMarkerLayer"
                 EnableSelection="False"
                 EnableHighlighting="False"
                 ToolTipEnabled="False">

                        <dxm:ListSourceDataAdapter DataSource="{Binding UAVWpMarkerList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings>
                                    <dxm:MapCustomElementSettings.ContentTemplate>
                                        <DataTemplate>
                                            <Canvas Width="0" Height="0">

                                                <Grid Canvas.Left="-6" Canvas.Top="-6" Width="12" Height="12">
                                                    <Grid.RenderTransform>
                                                        <RotateTransform Angle="{Binding Heading}" CenterX="6" CenterY="6"/>
                                                    </Grid.RenderTransform>

                                                    <Path Data="M 5,0 L 10,10 L 5,7.5 L 0,10 Z" 
                                      Fill="#1E90FF" 
                                      Stroke="Black" 
                                      StrokeThickness="1" 
                                      Stretch="Fill"/>
                                                </Grid>

                                                <Grid Canvas.Left="-50" Canvas.Top="15" Width="100">
                                                    <TextBlock Text="{Binding TagString}"
                                           FontSize="10" FontWeight="ExtraBold" Foreground="White"
                                           TextAlignment="Center" HorizontalAlignment="Center">
                                                        <!--<TextBlock.Effect>
                                                            <BlurEffect Radius="2" RenderingBias="Performance"/>
                                                        </TextBlock.Effect>-->
                                                    </TextBlock>

                                                    <TextBlock Text="{Binding TagString}"
                                           FontSize="10" FontWeight="Bold" Foreground="#111111" 
                                           TextAlignment="Center" HorizontalAlignment="Center"/>
                                                </Grid>

                                            </Canvas>
                                        </DataTemplate>
                                    </dxm:MapCustomElementSettings.ContentTemplate>
                                </dxm:MapCustomElementSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>

                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="INITMissionPolygonLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionPolygonList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Fill="White" Stroke="White" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points"/>-->
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                        <!--<dxm:VectorLayer.ShapeTitleOptions>
                            <dxm:ShapeTitleOptions Pattern="{}{Tag}"/>
                        </dxm:VectorLayer.ShapeTitleOptions>-->
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="INITMissionPolygonEditLayer" AllowEditItems="{Binding IsINITMissionPolygonEditMode}" EnableSelection="True">
                        <dxm:MapItemStorage x:Name="INITMissionPolygonEditStorage"/>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="FlightAreaPolygonLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False"
>
                        <dxm:ListSourceDataAdapter DataSource="{Binding FlightAreaPolygonList}">
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="FlightAreaPolygonEditLayer" AllowEditItems="{Binding IsFlightAreaEditMode}" EnableSelection="True">
                        <dxm:MapItemStorage x:Name="FlightAreaEditStorage"/>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="ProhibitedAreaPolygonLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False"
>
                        <dxm:ListSourceDataAdapter DataSource="{Binding ProhibitedAreaPolygonList}">
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="ProhibitedAreaPolygonEditLayer" AllowEditItems="{Binding IsProhibitedAreaEditMode}" EnableSelection="True">
                        <dxm:MapItemStorage x:Name="ProhibitedAreaEditStorage"/>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="TempINITMissionLineLayer" ShapeFill="Red" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TempINITMissionLineList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapLineSettings Stroke="Blue" IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>-->
                                <dxm:MapMultipointItemMappingInfo Points="Points" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

            

                    <dxm:VectorLayer x:Name="INITMissionLinePolygonLayer" ShapeFill="Transparent" ShapeStroke="Black" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionLinePolygonList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Stroke="Blue" IsHitTestVisible="False">
                                    <!--<dxm:MapLineSettings.StrokeStyle>
                                        <dxm:StrokeStyle 
                                            Thickness="3"        
                                            DashArray="4 2"
                                            DashCap="Round"
                                            StartLineCap="Round"
                                            EndLineCap="Round"
                                            LineJoin="Bevel"/>
                                    </dxm:MapLineSettings.StrokeStyle>-->
                                </dxm:MapPolygonSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="INITMissionLineLayer" ShapeFill="CadetBlue" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False" AllowEditItems="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionLineList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings  Stroke="CadetBlue" IsHitTestVisible="False">
                                    <!--<dxm:MapPolylineSettings.StrokeStyle>
                            <dxm:StrokeStyle 
                                Thickness="3"        
                                DashArray="4 2"
                                DashCap="Round"
                                StartLineCap="Round"
                                EndLineCap="Round"
                                LineJoin="Bevel"/>
                        </dxm:MapPolylineSettings.StrokeStyle>-->
                                </dxm:MapPolylineSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer Canvas.ZIndex="100">
                        <dxm:VectorLayer.Data>
                            <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionLineLabelList}">

                                <dxm:ListSourceDataAdapter.Mappings>
                                    <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                                </dxm:ListSourceDataAdapter.Mappings>

                                <dxm:ListSourceDataAdapter.ItemSettings>
                                    <dxm:MapCustomElementSettings>
                                        <dxm:MapCustomElementSettings.ContentTemplate>
                                            <DataTemplate>
                                                <Border Background="#D0FFFFFF" 
                                    BorderBrush="Black" 
                                    BorderThickness="1" 
                                    CornerRadius="10" 
                                    Padding="6,2">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform X="-20" Y="-10"/>
                                                    </Border.RenderTransform>

                                                    <TextBlock Text="{Binding TagString}" 
                                           FontFamily="Malgun Gothic"
                                           FontSize="12"
                                           FontWeight="ExtraBold"
                                           Foreground="Black" 
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </dxm:MapCustomElementSettings.ContentTemplate>
                                    </dxm:MapCustomElementSettings>
                                </dxm:ListSourceDataAdapter.ItemSettings>

                            </dxm:ListSourceDataAdapter>
                        </dxm:VectorLayer.Data>
                    </dxm:VectorLayer>



                    <dxm:VectorLayer x:Name="TempUnitDevelopPathPlanLayer" ShapeFill="Red" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TempUnitDevelopPathPlanList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="UnitDevelopPathPlanLayer" ShapeFill="BlueViolet" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding UnitDevelopPathPlanList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="TempCompINITMissionPointLayer" ShapeFill="Red" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TempINITMissionPointList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapDotSettings Size="12" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

               

                    <dxm:VectorLayer x:Name="INITMissionPointLayer"
                 EnableSelection="False"
                 EnableHighlighting="True"
                 ToolTipEnabled="False">
                        <dxm:VectorLayer.Data>
                            <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionPointList}">
                                <dxm:ListSourceDataAdapter.Mappings>
                                    <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                                </dxm:ListSourceDataAdapter.Mappings>
                                <dxm:ListSourceDataAdapter.ItemSettings>
                                    <dxm:MapCustomElementSettings>
                                        <dxm:MapCustomElementSettings.ContentTemplate>
                                            <DataTemplate>
                                                <Canvas Width="0" Height="0">
                                                    <!-- 점 중심을 맞추기 위해 -6, -6 -->
                                                    <Ellipse Width="12" Height="12"
                                         Fill="Blue"
                                         Stroke="White"
                                         StrokeThickness="1"
                                         Canvas.Left="-6"
                                         Canvas.Top="-6"/>

                                                    <!-- 텍스트는 점 아래에 8px 내려서 출력 -->
                                                    <TextBlock Text="{Binding TagString}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="Black"
                                           Width="60"
                                           TextAlignment="Center"
                                           Canvas.Left="-30"
                                           Canvas.Top="8"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"/>
                                                </Canvas>
                                            </DataTemplate>
                                        </dxm:MapCustomElementSettings.ContentTemplate>
                                    </dxm:MapCustomElementSettings>
                                </dxm:ListSourceDataAdapter.ItemSettings>
                            </dxm:ListSourceDataAdapter>
                        </dxm:VectorLayer.Data>
                    </dxm:VectorLayer>

                    <!--<dxm:VectorLayer x:Name="TakeOverPointLayer" ShapeFill="Blue" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TakeOverPointList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapDotSettings Size="8" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>-->

                    <dxm:VectorLayer x:Name="TakeOverPointLayer"
                            EnableSelection="False"
                            EnableHighlighting="True"
                            ToolTipEnabled="False">     
                        <dxm:VectorLayer.Data>
                            <dxm:ListSourceDataAdapter DataSource="{Binding TakeOverPointList}">
                                <dxm:ListSourceDataAdapter.Mappings>
                                    <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                                </dxm:ListSourceDataAdapter.Mappings>
                                <dxm:ListSourceDataAdapter.ItemSettings>
                                    <dxm:MapCustomElementSettings>
                                        <dxm:MapCustomElementSettings.ContentTemplate>
                                            <DataTemplate>
                                                <Canvas Width="0" Height="0">
                                                    <!-- 점 중심을 맞추기 위해 -6, -6 -->
                                                    <Ellipse Width="12" Height="12"
                                                        Fill="DarkBlue"
                                                        Stroke="White"
                                                        StrokeThickness="1"
                                                        Canvas.Left="-6"
                                                        Canvas.Top="-6"/>

                                                    <!-- 텍스트는 점 아래에 8px 내려서 출력 -->
                                                    <TextBlock Text="{Binding TagString}"
                                                        FontSize="10"
                                                        FontWeight="Bold"
                                                        Foreground="Black"
                                                        Width="200"
                                                        TextAlignment="Center"
                                                        Canvas.Left="-100"
                                                        Canvas.Top="8"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="Wrap"/>
                                                </Canvas>
                                            </DataTemplate>
                                        </dxm:MapCustomElementSettings.ContentTemplate>
                                    </dxm:MapCustomElementSettings>
                                </dxm:ListSourceDataAdapter.ItemSettings>
                            </dxm:ListSourceDataAdapter>
                        </dxm:VectorLayer.Data>
                    </dxm:VectorLayer>


                    <dxm:VectorLayer x:Name="HandOverPointLayer" ShapeFill="Blue" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False"
>
                        <dxm:ListSourceDataAdapter DataSource="{Binding HandOverPointList}">
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings>
                                    <dxm:MapCustomElementSettings.ContentTemplate>
                                        <DataTemplate>
                                            <Canvas Width="0" Height="0">
                                                <!-- 점 중심을 맞추기 위해 -6, -6 -->
                                                <Ellipse Width="12" Height="12"
                                   Fill="DarkRed"
                                   Stroke="White"
                                   StrokeThickness="1"
                                   Canvas.Left="-6"
                                   Canvas.Top="-6"/>

                                                <!-- 텍스트는 점 아래에 8px 내려서 출력 -->
                                                <TextBlock Text="{Binding TagString}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   Width="200"
                                   TextAlignment="Center"
                                   Canvas.Left="-100"
                                   Canvas.Top="8"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap"/>
                                            </Canvas>
                                        </DataTemplate>
                                    </dxm:MapCustomElementSettings.ContentTemplate>
                                </dxm:MapCustomElementSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="RTBPointLayer" ShapeFill="Blue" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding RTBPointList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings ContentTemplate="{StaticResource RTBSymbolTemplate}" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="FootprintSideLinesLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding FootprintSideLines}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapLineSettings Stroke="RosyBrown" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Points" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="ObjectDisplayLayer">
                        <dxm:ListSourceDataAdapter DataSource="{Binding ObjectDisplayList}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings 
                      ContentTemplate="{StaticResource ElementTemplate}" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Location.Latitude" Longitude="Location.Longitude" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                </dxm:MapControl.Layers>
                <dxm:MapControl.CoordinatesPanelOptions>
                    <dxm:CoordinatesPanelOptions Visible="False"/>
                </dxm:MapControl.CoordinatesPanelOptions>
                <dxm:MapControl.ScalePanelOptions>
                    <dxm:ScalePanelOptions ShowMilesScale="False"/>
                </dxm:MapControl.ScalePanelOptions>
                <dxm:MapControl.ScrollButtonsOptions>
                    <dxm:ScrollButtonsOptions Visible="False"/>
                </dxm:MapControl.ScrollButtonsOptions>
                <dxm:MapControl.ZoomTrackbarOptions>
                    <dxm:ZoomTrackbarOptions HorizontalAlignment="Right"/>
                </dxm:MapControl.ZoomTrackbarOptions>
            </dxm:MapControl>

            <Border HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Margin="0,20,0,0" 
                Padding="15,10"
                CornerRadius="8"
                BorderBrush="#88FFFFFF"
                BorderThickness="1"
                IsHitTestVisible="False"
                Visibility="{Binding Source={x:Static local:ViewModel_UC_Unit_MissionPackage.SingletonInstance}, Path=IsInfoPanelVisible, Converter={StaticResource BoolToVis}}">

                <Border.Background>
                    <SolidColorBrush Color="Black" Opacity="0.75"/>
                </Border.Background>

                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static local:ViewModel_UC_Unit_MissionPackage.SingletonInstance}, Path=CurrentModeTitle}"
                           Foreground="#FFD700" 
                           FontWeight="ExtraBold" 
                           FontSize="16" 
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"/>

                    <Separator Background="Gray" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="좌표 선택/해제 : " Foreground="White" FontSize="13"/>
                        <TextBlock Text="{Binding Source={x:Static local:ViewModel_UC_Unit_MissionPackage.SingletonInstance}, Path=CurrentShortcutKey}" 
                               Foreground="Cyan" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="생성 완료 (저장) : " Foreground="White" FontSize="13"/>
                        <TextBlock Text="Enter" Foreground="#00FF00" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="취소 : " Foreground="White" FontSize="12"/>
                        <TextBlock Text="ESC" Foreground="Red" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border HorizontalAlignment="Center" 
        VerticalAlignment="Top" 
        Margin="0,20,0,0" 
        Padding="15,10"
        CornerRadius="8"
        BorderBrush="#88FFFFFF"
        BorderThickness="1"
        IsHitTestVisible="False"
        Visibility="{Binding Source={x:Static local:ViewModel_UC_Unit_INITMissionInfo.SingletonInstance}, Path=IsInfoPanelVisible, Converter={StaticResource BoolToVis}}">

                <Border.Background>
                    <SolidColorBrush Color="Black" Opacity="0.75"/>
                </Border.Background>

                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static local:ViewModel_UC_Unit_INITMissionInfo.SingletonInstance}, Path=CurrentModeTitle}"
                   Foreground="#FFD700" FontWeight="ExtraBold" FontSize="16" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <Separator Background="Gray" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="좌표 선택/해제 : " Foreground="White" FontSize="13"/>
                        <TextBlock Text="{Binding Source={x:Static local:ViewModel_UC_Unit_INITMissionInfo.SingletonInstance}, Path=CurrentShortcutKey}" 
                       Foreground="Cyan" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="생성 완료 (저장) : " Foreground="White" FontSize="13"/>
                        <TextBlock Text="Enter" Foreground="#00FF00" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="취소 : " Foreground="White" FontSize="12"/>
                        <TextBlock Text="ESC" Foreground="Red" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border HorizontalAlignment="Center" 
        VerticalAlignment="Top" 
        Margin="0,20,0,0" 
        Padding="15,10"
        CornerRadius="8"
        BorderBrush="#88FFFFFF"
        BorderThickness="1"
        IsHitTestVisible="False"
        Visibility="{Binding Source={x:Static local:ViewModel_ScenarioObject_PopUp.SingletonInstance}, Path=IsInfoPanelVisible, Converter={StaticResource BoolToVis}}">

                <Border.Background>
                    <SolidColorBrush Color="Black" Opacity="0.75"/>
                </Border.Background>

                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static local:ViewModel_ScenarioObject_PopUp.SingletonInstance}, Path=CurrentModeTitle}"
                   Foreground="#FFD700" FontWeight="ExtraBold" FontSize="16" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <Separator Background="Gray" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="좌표 선택/해제 : " Foreground="White" FontSize="13"/>
                        <TextBlock Text="{Binding Source={x:Static local:ViewModel_ScenarioObject_PopUp.SingletonInstance}, Path=CurrentShortcutKey}" 
                       Foreground="Cyan" FontWeight="Bold" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Canvas x:Name="FocusOverlay" 
            IsHitTestVisible="False" 
            Visibility="Collapsed">
                <Rectangle x:Name="FocusRectangle" IsHitTestVisible="False"
                   Width="{Binding ElementName=FocusOverlay, Path=ActualWidth}"
                   Height="{Binding ElementName=FocusOverlay, Path=ActualHeight}" />

                <Line x:Name="CrosshairX" Stroke="Red" StrokeThickness="1" StrokeDashArray="2 2" IsHitTestVisible="False"/>
                <Line x:Name="CrosshairY" Stroke="Red" StrokeThickness="1" StrokeDashArray="2 2" IsHitTestVisible="False"/>

            </Canvas>
        </Grid>

        <!--<Grid Grid.Row="1" Grid.ColumnSpan="2" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,0,0,0">
                <Button x:Name="btnToggleMap" 
                Content="Web Map" 
                Width="130" Height="25" 
                FontSize="11" FontWeight="Bold"
                Click="btnToggleMap_Click"
                Background="#333333" Foreground="White"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="위도 : " Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <TextBlock Grid.Column="2" x:Name="MapLat" Text="{Binding MapCursorLat, StringFormat=F5}"  Background="{StaticResource DefaultBg_Brush}" Height="20" Style="{StaticResource NormalTextBlock}"/>
            <TextBlock Grid.Column="3" Text="°" Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>

            <TextBlock Grid.Column="4" Text="경도 : " Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <TextBlock Grid.Column="5" x:Name="MapLon" Text="{Binding MapCursorLon, StringFormat=F5}"  Background="{StaticResource DefaultBg_Brush}" Height="20" Style="{StaticResource NormalTextBlock}"/>
            <TextBlock Grid.Column="6" Text="°" Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>

            <TextBlock Grid.Column="7" Text="고도 : " Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <TextBlock Grid.Column="8" x:Name="MapAlt" Text="{Binding MapCursorAlt, StringFormat=F0}" Background="{StaticResource DefaultBg_Brush}" Height="20" Style="{StaticResource NormalTextBlock}"/>
            <TextBlock Grid.Column="9" Text="m" Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
        </Grid>-->

        <Grid Grid.Row="1" Grid.ColumnSpan="2" VerticalAlignment="Top">
            <Border Background="#80080A10" BorderBrush="#4000F0FF" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                        <ToggleButton x:Name="FilterToggle"
                                      Content="Filter"
                                      Width="80" Height="28"
                                      Foreground="#00F0FF"
                                      Background="#40000000"
                                      BorderBrush="#8000F0FF"
                                      BorderThickness="1"
                                      FontSize="12" FontWeight="Bold">
                            <ToggleButton.Effect>
                                <DropShadowEffect Color="#00F0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.4"/>
                            </ToggleButton.Effect>
                        </ToggleButton>

                        <Popup IsOpen="{Binding IsChecked, ElementName=FilterToggle}"
                               StaysOpen="False"
                               PlacementTarget="{Binding ElementName=FilterToggle}"
                               Placement="Top"
                               AllowsTransparency="True">
                            <Border Background="#F2080A10"
                                    BorderBrush="{StaticResource SciFi_Cyan}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10"
                                    Margin="0,0,0,5">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00F0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="지도 필터" Foreground="{StaticResource SciFi_Cyan}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                                    <StackPanel>
                                        <StackPanel.Resources>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Margin" Value="5,3"/>
                                                <Setter Property="LayoutTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </StackPanel.Resources>
                                        <CheckBox Content="객체 번호" IsChecked="{Binding FilterEntityID}"/>
                                        <CheckBox Content="비행참조정보" IsChecked="{Binding FilterFlightRefInfo}"/>
                                        <CheckBox Content="LAH 계획" IsChecked="{Binding FilterLAHPlan}"/>
                                        <CheckBox Content="UAV 계획" IsChecked="{Binding FilterUAVPlan}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button x:Name="btnToggleMap"
                                Content="Web Map"
                                Width="120" Height="28"
                                Margin="8,0,0,0"
                                Style="{StaticResource HudButtonStyle}"
                                Click="btnToggleMap_Click">
                            <Button.Effect>
                                <DropShadowEffect Color="#00F0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.4"/>
                            </Button.Effect>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">

                        <Border Background="#40000510" BorderBrush="#3000F0FF" BorderThickness="1" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="위도" Foreground="#00F0FF" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="MapLat" Text="{Binding MapCursorLat, StringFormat=F5}" Foreground="White" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold" MinWidth="75" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="°" Foreground="#80FFFFFF" FontSize="11" Margin="3,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#40000510" BorderBrush="#3000F0FF" BorderThickness="1" CornerRadius="4" Padding="10,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="경도" Foreground="#00F0FF" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="MapLon" Text="{Binding MapCursorLon, StringFormat=F5}" Foreground="White" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold" MinWidth="80" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="°" Foreground="#80FFFFFF" FontSize="11" Margin="3,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#40000510" BorderBrush="#3000F0FF" BorderThickness="1" CornerRadius="4" Padding="10,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="고도" Foreground="#00F0FF" FontSize="11" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="MapAlt" Text="{Binding MapCursorAlt, StringFormat=F0}" Foreground="White" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold" MinWidth="45" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="m" Foreground="#80FFFFFF" FontSize="11" Margin="3,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
    


</UserControl>

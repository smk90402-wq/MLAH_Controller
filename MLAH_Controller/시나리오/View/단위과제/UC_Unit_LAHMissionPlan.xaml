<UserControl x:Class="MLAH_Controller.UC_Unit_LAHMissionPlan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d" 
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        dx:ThemeManager.ThemeName="Win11Dark"
        Height="1160" Width="520" 
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  
        >


    <UserControl.DataContext>
        <Binding Source="{x:Static local:ViewModel_UC_Unit_LAHMissionPlan.SingletonInstance}"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <local:TypeToStringConverter x:Key="TypeToStringConverter" />
        <local:MissionTypeToStringConverter x:Key="MissionTypeToStringConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="350"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--<TextBlock Text="비행참조정보 패키지 ID" Style="{StaticResource NormalTextBlock}" Foreground="White" Margin="10,20,0,0"/>
        <TextBlock Text="1" Style="{StaticResource NormalTextBlock}"  Margin="160,20,0,0"/>-->

        <!--<Button Grid.Row="6" Grid.Column="1" 
            Content="테스트 데이터 로드" 
            Command="{Binding LoadDummyDataCommand}"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,22,15,0" Width="140" Height="25"
            Style="{StaticResource NormalButtonStyle}" />-->

        <GroupBox Grid.ColumnSpan="2" Grid.RowSpan="5" Header="유인기 임무계획" Foreground="{StaticResource SciFi_Cyan}" BorderBrush="{StaticResource SciFi_Border}" Margin="0,0,0,10"/>
        

        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10,20,0,0">
            <!--<TextBlock Text="임무계획 ID" Grid.Row="0" Style="{StaticResource NormalTextBlock}" Foreground="White" Margin="{StaticResource UIELEMENT_MARGIN}" VerticalAlignment="Top"/>
            <TextBlock Text="임무계획 ID" Grid.Row="1" Style="{StaticResource NormalTextBlock}" Foreground="White" Margin="{StaticResource UIELEMENT_MARGIN}" VerticalAlignment="Top"/>
            <TextBlock Text="임무계획 ID" Grid.Row="2" Style="{StaticResource NormalTextBlock}" Foreground="White" Margin="{StaticResource UIELEMENT_MARGIN}" VerticalAlignment="Top"/>-->

            <!--<DataGrid Grid.Column="0" Grid.ColumnSpan="2"  Style="{StaticResource NormalDataGrid}" ItemsSource="{Binding LAHMissionPlanItemSource}"  SelectedIndex="{Binding LAHMissionPlanSelectedIndex}" Height="150" VerticalAlignment="Top" HorizontalScrollBarVisibility="Hidden" 
          AlternationCount="10000" Margin="10">
                
                <DataGrid.Columns>
           
                    <DataGridTextColumn Header="임무계획 ID" Width="150" IsReadOnly="True" Binding="{Binding MissionPlanID}"/>
                    <DataGridTextColumn Header="대상 유인기" Width="150" IsReadOnly="True" Binding="{Binding AircraftID}"/>
                    <DataGridTextColumn Header="협업기저임무 수" Width="200" IsReadOnly="True" Binding="{Binding MissionSegemntN}"/>
                    
                </DataGrid.Columns>
                <i:Interaction.Behaviors>
                    <local:BindableSelectedItemBehaviorForDataGrid SelectedItem="{Binding LAHMissionPlanSelectedItem,Mode=TwoWay}" />
                </i:Interaction.Behaviors>
            </DataGrid>-->

            <dxg:GridControl Grid.Column="0" Width="500" ItemsSource="{Binding LAHMissionPlanItemSource}" 
                             SelectedItem="{Binding LAHMissionPlanSelectedItem}"
                             AutoGenerateColumns="None" Background="#CC0A0E17"
                             Height="100" 
                             VerticalAlignment="Top">

                <dxg:GridControl.View>
                    <dxg:TableView ShowGroupPanel="False"
                        AllowResizing="False"
                        HorizontalScrollbarVisibility="Hidden"
                        AllowEditing="True"
                        AllowColumnFiltering="False"
                        AllowColumnMoving="False"
                        AllowSorting="False"
                        NavigationStyle="Cell"
                        EditorShowMode="MouseDown"
                        EnableImmediatePosting="True"
                                   ShowIndicator="False"
                        FocusedRowHandle ="{Binding LAHMissionPlanSelectedIndex}">
                    </dxg:TableView>
                </dxg:GridControl.View>

                <dxg:GridControl.Columns>

                    <dxg:GridColumn FieldName="MissionPlanID" Header="임무계획 ID" Width="2*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="AircraftID" Header="대상 유인기" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="MissionSegemntN" Header="협업기저임무 수" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                </dxg:GridControl.Columns>
            </dxg:GridControl>
        </Grid>
        

        <GroupBox Grid.ColumnSpan="2" Grid.Row="1" Header="협업기저임무 목록" BorderBrush="{StaticResource SciFi_Border}" Foreground="{StaticResource SciFi_Cyan}" Margin="10,5,10,0" Height="180" VerticalAlignment="Top">
            <Grid>
                <!--<DataGrid Grid.Column="0" Style="{StaticResource NormalDataGrid}" ItemsSource="{Binding MissionSegmentItemSource}"  SelectedIndex="{Binding MissionSegmentSelectedIndex}" Height="240" VerticalAlignment="Top" HorizontalScrollBarVisibility="Hidden" 
                          AlternationCount="10000" >
                    --><!--GridLinesVisibility="All" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"--><!--
                    <DataGrid.Columns>
                        --><!-- 순번 컬럼 -->
                        <!--<DataGridTextColumn Header="순번" Width="30" IsReadOnly="True">
                            <DataGridTextColumn.Binding>
                                <Binding Path="(ItemsControl.AlternationIndex)" RelativeSource="{RelativeSource AncestorType=DataGridRow}" Converter="{StaticResource IndexPlusOneConverter}" />
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>-->

                        <!-- 나머지 실제 데이터 컬럼들 --><!--
                        <DataGridTextColumn Header="협업기저임무 ID" Width="120" IsReadOnly="True" Binding="{Binding MissionSegmentID}"/>
                        --><!--<DataGridTextColumn Header="임무 구간" Width="80" IsReadOnly="True" Binding="{Binding RelatedInputMissionID}"/>--><!--
                        <DataGridTextColumn Header="수행완료 여부" Width="120" IsReadOnly="True" Binding="{Binding IsDone}"/>
                        <DataGridTextColumn Header="임무 유형" Width="120" IsReadOnly="True" Binding="{Binding MissionSegmentType, Converter={StaticResource MissionTypeToStringConverter}}"/>
                        <DataGridTextColumn Header="개별임무 수" Width="100" IsReadOnly="True" Binding="{Binding IndividualMissionLisnN}"/>
                    </DataGrid.Columns>
                    <i:Interaction.Behaviors>
                        <local:BindableSelectedItemBehaviorForDataGrid SelectedItem="{Binding MissionSegmentSelectedItem,Mode=TwoWay}" />
                    </i:Interaction.Behaviors>
                </DataGrid>-->

                <dxg:GridControl ItemsSource="{Binding MissionSegmentItemSource}" 
                 SelectedItem="{Binding MissionSegmentSelectedItem}"
                 AutoGenerateColumns="None" Background="#CC0A0E17"
                 Height="140" 
                 VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
                            AllowResizing="False"
                            HorizontalScrollbarVisibility="Hidden"
                            AllowEditing="True"
                            AllowColumnFiltering="False"
                            AllowColumnMoving="False"
                            AllowSorting="False"
                            NavigationStyle="Cell"
                            EditorShowMode="MouseDown"
                            EnableImmediatePosting="True"
                                       ShowIndicator="False"
                            FocusedRowHandle ="{Binding MissionSegmentSelectedIndex}">
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>

                        <dxg:GridColumn FieldName="MissionSegmentID" Header="협업기저임무 ID" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="IsDone" Header="수행완료 여부" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:CheckEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="MissionSegmentType" Header="임무 유형" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings DisplayTextConverter="{StaticResource MissionTypeToStringConverter}" HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="IndividualMissionLisnN" Header="개별임무 수" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                    </dxg:GridControl.Columns>
                </dxg:GridControl>

            </Grid>
        </GroupBox>

        <GroupBox Grid.ColumnSpan="2" Grid.Row="2" Header="개별 임무" BorderBrush="{StaticResource SciFi_Border}" Foreground="{StaticResource SciFi_Cyan}" Margin="10,0,10,0" Height="180" VerticalAlignment="Top" >
            <Grid>
              

                <!--<DataGrid Grid.Column="0" Style="{StaticResource NormalDataGrid}" ItemsSource="{Binding IndividualMissionPlanItemSource}"  SelectedIndex="{Binding IndividualMissionPlanSelectedIndex}" Height="240" VerticalAlignment="Top" HorizontalScrollBarVisibility="Hidden">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="개별임무 ID" Width="150" IsReadOnly="True" Binding="{Binding IndividualMissionID}"/>
                        <DataGridTextColumn Header="임무 완료 여부" Width="150" IsReadOnly="True" Binding="{Binding IsDone}"/>
                        <DataGridTextColumn Header="경로점 개수" Width="150" IsReadOnly="True" Binding="{Binding WaypointListN}"/>
                        --><!--<DataGridTextColumn Header="경도" Width="70" IsReadOnly="True" Binding="{Binding LON, StringFormat=F5}"/>
                        <DataGridTextColumn Header="고도" Width="70" IsReadOnly="True" Binding="{Binding ALT, StringFormat=F1}"/>--><!--
                    </DataGrid.Columns>
                    <i:Interaction.Behaviors>
                        <local:BindableSelectedItemBehaviorForDataGrid SelectedItem="{Binding IndividualMissionPlanSelectedItem,Mode=TwoWay}" />
                    </i:Interaction.Behaviors>
                </DataGrid>-->

                <dxg:GridControl ItemsSource="{Binding IndividualMissionPlanItemSource}" 
                        SelectedItem="{Binding IndividualMissionPlanSelectedItem}"
                        AutoGenerateColumns="None"  
                        Height="140" 
                        VerticalAlignment="Top"
                                 Background="#CC0A0E17">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
                            AllowResizing="False"
                            HorizontalScrollbarVisibility="Hidden"
                            AllowEditing="True"
                            AllowColumnFiltering="False"
                            AllowColumnMoving="False"
                            AllowSorting="False"
                            NavigationStyle="Cell"
                            EditorShowMode="MouseDown"
                            EnableImmediatePosting="True"
                                       ShowIndicator="False"
                            FocusedRowHandle ="{Binding IndividualMissionPlanSelectedIndex}">
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>

                        <dxg:GridColumn FieldName="IndividualMissionID" Header="개별임무 ID" Width="2*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="IsDone" Header="임무 완료 여부" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:CheckEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="WaypointListN" Header="경로점 개수" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                    </dxg:GridControl.Columns>
                </dxg:GridControl>

            </Grid>
        </GroupBox>

        <GroupBox Grid.ColumnSpan="2" Grid.Row="3" Header="경로점" BorderBrush="{StaticResource SciFi_Border}" Foreground="{StaticResource SciFi_Cyan}" Margin="10,0,10,0" Height="310" VerticalAlignment="Top" >
            <Grid Background="#CC0A0E17">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--<DataGrid Grid.Column="0" Style="{StaticResource NormalDataGrid}" ItemsSource="{Binding WayPointLAHItemSource}"  SelectedIndex="{Binding WayPointLAHSelectedIndex}" Height="250" VerticalAlignment="Top" HorizontalScrollBarVisibility="Hidden" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="경로점 ID" Width="70" IsReadOnly="True" Binding="{Binding WaypoinID}"/>
                        --><!--<DataGridTextColumn Header="위도" Width="80" IsReadOnly="True" Binding="{Binding LAT,StringFormat=F5}"/>
                        <DataGridTextColumn Header="경도" Width="80" IsReadOnly="True" Binding="{Binding LON, StringFormat=F5}"/>
                        <DataGridTextColumn Header="고도" Width="80" IsReadOnly="True" Binding="{Binding ALT, StringFormat=F1}"/>--><!--
                    </DataGrid.Columns>
                    <i:Interaction.Behaviors>
                        <local:BindableSelectedItemBehaviorForDataGrid SelectedItem="{Binding WayPointLAHSelectedItem,Mode=TwoWay}" />
                    </i:Interaction.Behaviors>
                </DataGrid>-->

                <dxg:GridControl Grid.Column="0" Width="180" ItemsSource="{Binding WayPointLAHItemSource}" 
                 SelectedItem="{Binding WayPointLAHSelectedItem}"
                 AutoGenerateColumns="None" Background="#CC0A0E17"
                 Height="270" 
                 VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
            AllowResizing="False"
            HorizontalScrollbarVisibility="Hidden"
            AllowEditing="True"
            AllowColumnFiltering="False"
            AllowColumnMoving="False"
            AllowSorting="False"
            NavigationStyle="Cell"
            EditorShowMode="MouseDown"
            EnableImmediatePosting="True"
                                       ShowIndicator="False"
            FocusedRowHandle ="{Binding WayPointLAHSelectedIndex}">
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>

                        <dxg:GridColumn FieldName="WaypoinID" Header="경로점 ID" Width="2*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                     

                    </dxg:GridControl.Columns>
                </dxg:GridControl>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        
                    </Grid.RowDefinitions>

                    <!--<ToggleButton Grid.Column="0" Grid.Row="0" Style="{StaticResource POSSelectToggleButtonStyle}" IsEnabled="{Binding PolygonTypeEnable}"  HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding PolygonTypeChecked}" />-->
                    
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="위도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding WayPointLAH_LAT}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBlock Grid.Column="0" Grid.Row="1" Text="경도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding WayPointLAH_LON}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Column="2" Grid.Row="1" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBlock Grid.Column="0" Grid.Row="2" Text="고도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="{Binding WayPointLAH_ALT}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Column="2" Grid.Row="2" Text=" m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBlock Grid.Column="0" Grid.Row="3" Text="속도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="3" Text="{Binding WayPointLAH_Speed}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Column="2" Grid.Row="3" Text=" m/s" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>


                    <TextBlock Grid.Column="0" Grid.Row="4" Text="ETA" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="4" Text="{Binding WayPointLAH_ETA}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Column="2" Grid.Row="4" Text=" s" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>


                    <TextBlock Grid.Column="0" Grid.Row="5" Text="다음 경로점 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="5" Text="{Binding WayPointLAH_Next}" Style="{StaticResource NormalTextBlock}"/>


                    <TextBlock Grid.Column="0" Grid.Row="6" Text="제자리비행 시간" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="6" Text="{Binding WayPointLAH_Hovering}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Column="2" Grid.Row="6" Text=" s" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBlock Grid.Column="0" Grid.Row="7" Text="공격대상 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="7" Text="{Binding WayPointLAH_AttackTargetID}" Style="{StaticResource NormalTextBlock}"/>

                    <TextBlock Grid.Column="0" Grid.Row="8" Text="추천 무장" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <ComboBox Grid.Column="1" Grid.Row="8" Style="{StaticResource NormalComboBox}" Height="25" Width="100" Margin="-10,0,0,0" SelectedIndex="{Binding WayPointLAH_AttackType}" HorizontalAlignment="Left" IsEnabled="False" >
                        <ComboBoxItem Content="공격 없음" />
                        <ComboBoxItem Content="Type 1" />
                        <ComboBoxItem Content="Type 2" />
                        <ComboBoxItem Content="Type 3" />
                    </ComboBox>


                    <!--<Button Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Content="생성" Style="{StaticResource NormalButtonStyle}" Height="20" Width="50" HorizontalAlignment="Left"/>
                    <Button Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Content="수정" Style="{StaticResource NormalButtonStyle}" Height="20" Width="50" HorizontalAlignment="Left" Margin="55,0,0,0"/>
                    <Button Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Content="삭제" Style="{StaticResource NormalButtonStyle}" Height="20" Width="50" HorizontalAlignment="Left" Margin="110,0,0,0"/>-->

                    

                    

                    
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.ColumnSpan="2" Grid.Row="4"  BorderBrush="{StaticResource SciFi_Border}" Foreground="{StaticResource SciFi_Cyan}" Margin="10,0,10,0" Height="240" VerticalAlignment="Top" >
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="임무 통제 (전장환경모의)" Foreground="{StaticResource SciFi_Cyan}" VerticalAlignment="Center"/>
                    <CheckBox Content="자동 임무 수행" 
                      IsChecked="{Binding IsAutoExecutionMode}" 
                      Foreground="#00FF00" 
                      Margin="20,0,0,0" 
                      VerticalAlignment="Center"
                      ToolTip="체크 시 인가/완료 후 즉시 다음 임무를 수행합니다."/>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#3000F0FF" Grid.Column="0"  BorderThickness="1"/>
                <Border BorderBrush="#3000F0FF" Grid.Column="1"  BorderThickness="1"/>
                <Border BorderBrush="#3000F0FF" Grid.Column="2"  BorderThickness="1"/>


                <Grid Grid.Column="0"  Background="#CC0A0E17">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="유인기 1" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="인가 종류"  Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="개별 ID"  Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="완료"  Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="다음 ID"  Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" HorizontalAlignment="Left" Margin="5,0,0,0"/>
                    <Button Grid.Row="5" Grid.Column="0" Style="{StaticResource HudButtonStyle}" Content="임무 시작" Height="25" Margin="5,0,0,0" Command="{Binding Button1Command}" FontSize="11"/>

                    <TextBlock Grid.Row="1" Grid.Column="1"  Text="{Binding ControlDecisionType1}" Style="{StaticResource NormalTextBlock}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"  Text="{Binding ControlIndividualID1}" Style="{StaticResource NormalTextBlock}"/>
                    <!--<TextBlock Grid.Row="3" Grid.Column="1"  Text="{Binding ControlMissionDone1}" Style="{StaticResource NormalTextBlock}"/>-->

                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ControlMissionDone1}" Opacity="{Binding ControlStatusOpacity1}" HorizontalAlignment="Left" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource NormalTextBlock}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ControlMissionDone1}" Value="O">
                                        <Setter Property="Foreground" Value="#00BFFF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ControlMissionDone1}" Value="X">
                                        <Setter Property="Foreground" Value="#FF4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ControlMissionDone1}" Value="-">
                                        <Setter Property="Foreground" Value="Gray"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="4" Grid.Column="1"  Text="{Binding ControlNextID1}" Style="{StaticResource NormalTextBlock}" />


                </Grid>

                <Grid Grid.Column="1"  Background="#CC0A0E17">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>

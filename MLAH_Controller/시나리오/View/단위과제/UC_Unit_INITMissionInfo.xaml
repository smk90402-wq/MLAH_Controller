<UserControl x:Class="MLAH_Controller.UC_Unit_INITMissionInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        mc:Ignorable="d"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        dx:ThemeManager.ThemeName="Win11Dark"
        Height="1160" Width="520"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"
        >


    <UserControl.DataContext>
        <Binding Source="{x:Static local:ViewModel_UC_Unit_INITMissionInfo.SingletonInstance}"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <local:TypeToStringConverter x:Key="TypeToStringConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="510"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="400"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="270"/>
            <RowDefinition Height="250"/>
            <!--<RowDefinition Height="250"/>-->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.ColumnSpan="2" Grid.RowSpan="6" Header="협업기저임무 목록" Foreground="{StaticResource SciFi_Cyan}" Margin="0,0,0,1" BorderBrush="{StaticResource SciFi_Border}" BorderThickness="1"/>
        <GroupBox Grid.Row="2" Grid.RowSpan="4" Header="협업기저임무 상세정보" Foreground="{StaticResource SciFi_Cyan}" Margin="5,5,5,5" BorderBrush="{StaticResource SciFi_Border}"/>


        <GroupBox Grid.Row="3" Foreground="{StaticResource SciFi_Cyan}" Margin="10,10,10,10" Height="80" VerticalAlignment="Top" IsEnabled="{Binding EditEnable}" BorderBrush="{StaticResource SciFi_Border}">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="좌표 정보 (Point)" GroupName="CoordType" IsChecked="{Binding IsPointSelected}" IsEnabled="{Binding IsShapeTypeEditable}"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid IsEnabled="{Binding IsPointSelected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="10"/>

                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="20"/>

                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="20"/>

                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="10"/>
                </Grid.ColumnDefinitions>

                <ToggleButton Grid.Column="0" Style="{StaticResource HudToggleIcon_25}"  HorizontalAlignment="Center" IsChecked="{Binding PointTypeChecked}" IsEnabled="{Binding EditEnable}"/>

                <TextBlock Grid.Column="2" Text="위도 : " Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                <TextBox Grid.Column="3" Text="{Binding PointLat_Control,StringFormat=F5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                <TextBlock Grid.Column="5" Text="°" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                <TextBlock Grid.Column="6" Text="경도 : " Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                <TextBox Grid.Column="7" Text="{Binding PointLon_Control,StringFormat=F5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                <TextBlock Grid.Column="9" Text="°" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                <TextBlock Grid.Column="10" Text="고도 : " Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                <TextBox Grid.Column="11" Text="{Binding PointAlt_Control}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                <TextBlock Grid.Column="13" Text="m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

            </Grid>
        </GroupBox>



        <GroupBox Grid.Row="4" Foreground="{StaticResource SciFi_Cyan}" Margin="10,10,10,10" Height="250" VerticalAlignment="Top" BorderBrush="{StaticResource SciFi_Border}" BorderThickness="2">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="좌표 정보 (Line)" GroupName="CoordType" IsChecked="{Binding IsLineSelected}" IsEnabled="{Binding IsShapeTypeEditable}"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid IsEnabled="{Binding IsLineSelected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <dxg:GridControl Grid.Column="0" x:Name="LineGrid" ItemsSource="{Binding LinearLOCList}" SelectedItem="{Binding SelectedLineItem}"
                    AutoGenerateColumns="None" Height="150" VerticalAlignment="Top">
                    
                    <dxg:GridControl.View>
                        <dxg:TableView
                    ShowGroupPanel="False"
                    AllowResizing="False"
                    HorizontalScrollbarVisibility="Hidden"
                    AllowEditing="True"
                    AllowColumnFiltering="False"
                    AllowColumnMoving="False"
                    AllowSorting="False"
                    NavigationStyle="Cell"
                    EditorShowMode="MouseDown"
                    EnableImmediatePosting="True"
                    ShowIndicator="False"
                    >
                    </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>
                        
                        <dxg:GridColumn FieldName="Latitude" Header="위도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="f5" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Longitude" Header="경도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="f5" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Altitude" Header="고도" Width="70" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                    </dxg:GridControl.Columns>
                    
                    
                    
                </dxg:GridControl>


                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Column="0" Grid.Row="0" Style="{StaticResource HudToggleIcon_25}" IsEnabled="{Binding EditEnable}"  HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding LinearTypeChecked}" />

                    <!--<TextBlock Grid.Column="1" Grid.Row="0" Text="위도" Style="{StaticResource NormalTextBlock}" Foreground="White"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="경도" Style="{StaticResource NormalTextBlock}" Foreground="White"/>-->
                    <!--<TextBlock Grid.Column="1" Grid.Row="0" Text="고도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>-->

                    <TextBlock Grid.Column="1" Grid.Row="0" Text="너비" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    

                    <!--<Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="선택지점 수정" Style="{StaticResource NormalButtonStyle}" Height="25" HorizontalAlignment="Left" IsEnabled="False"/>
                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="선택지점 삭제" Style="{StaticResource NormalButtonStyle}" Height="25" HorizontalAlignment="Left" IsEnabled="False" Margin="90,0,0,0"/>-->



                    <!--<TextBox Grid.Column="2" Grid.Row="0" Text="{Binding LineLatControl, StringFormat=F5, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="0" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="White"/>

                    <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding LineLonControl, StringFormat=F5, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="1" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="White"/>-->

                    <!--<TextBox Grid.Column="2" Grid.Row="0" Text="{Binding LineAltControl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="0" Text=" m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>-->

                    <TextBox Grid.Column="2" Grid.Row="0" Text="{Binding WidthControl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="0" Text=" m" Margin="0,0,0,0" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                </Grid>


            </Grid>
        </GroupBox>

       

        <GroupBox Grid.Row="5" Foreground="{StaticResource SciFi_Cyan}" Margin="10,10,10,10" Height="230" VerticalAlignment="Top"
          IsEnabled="True" BorderBrush="{StaticResource SciFi_Border}">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="좌표 정보 (Area)" GroupName="CoordType" 
                         IsChecked="{Binding IsAreaSelected}" Foreground="White" 
                         IsEnabled="{Binding IsShapeTypeEditable}"/>
                </StackPanel>
            </GroupBox.Header>

            <Grid IsEnabled="{Binding IsAreaSelected}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <dxg:GridControl Grid.Column="0"
                         ItemsSource="{Binding AreaWrapperList}"
                         SelectedItem="{Binding SelectedAreaWrapper}"
                         Height="220"
                         Background="{StaticResource MLAH_COLOR_POPUP_DLG_BG_Brush}"
                         VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" 
                               AllowEditing="False" 
                               NavigationStyle="Row"
                               ShowIndicator="False"
                               AllowColumnFiltering="False"
                               AllowSorting="False"
                                       
                               AllowMasterDetail="True"/>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>
                        
                        <dxg:GridColumn Header="Index" FieldName="UI_ID" Width="60" HorizontalHeaderContentAlignment="Center" ReadOnly="True"/>
                        
                        <dxg:GridColumn Header="제외구역 여부" FieldName="IsHole" Width="*" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:CheckEditSettings HorizontalContentAlignment="Center" IsThreeState="False"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <!--<dxg:GridColumn Header="삭제" Width="40" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" 
                                    Command="{Binding View.DataContext.PolygonButton3Command}" 
                                    CommandParameter="{Binding RowData.Row}"
                                    Style="{StaticResource NormalButtonStyle}" 
                                    IsEnabled="{Binding View.DataContext.PolygonEditEnable}"
                                    Background="#AAFF5555" Height="18" FontSize="10"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>-->
                    </dxg:GridControl.Columns>

                    <dxg:GridControl.DetailDescriptor>
                        <dxg:DataControlDetailDescriptor ItemsSourcePath="Points">
                            <dxg:GridControl AutoGenerateColumns="None">
                                <dxg:GridControl.View>
                                    <dxg:TableView ShowGroupPanel="False" ShowIndicator="False" DetailHeaderContent="Points" AllowEditing="False" AllowSorting="False" AllowColumnFiltering="False"/>
                                </dxg:GridControl.View>
                                <dxg:GridControl.Columns>

                                    <dxg:GridColumn FieldName="Latitude" Header="위도" Width="*" HorizontalHeaderContentAlignment="Center" AllowSorting="False" AllowEditing="False" AllowColumnFiltering="False">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:TextEditSettings MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <dxg:GridColumn FieldName="Longitude" Header="경도" Width="*" HorizontalHeaderContentAlignment="Center" AllowColumnFiltering="False">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:TextEditSettings MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <dxg:GridColumn FieldName="Altitude" Header="고도" Width="*" HorizontalHeaderContentAlignment="Center" AllowColumnFiltering="False">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:TextEditSettings MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>
                                    
                                </dxg:GridControl.Columns>
                                
                            </dxg:GridControl>
                        </dxg:DataControlDetailDescriptor>
                    </dxg:GridControl.DetailDescriptor>
                </dxg:GridControl>

                <Grid Grid.Column="1" Margin="5,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>

                    <ToggleButton Grid.Row="0" Grid.Column="0" Style="{StaticResource HudToggleIcon_25}"  Margin="-25,0,0,0"  
                          IsEnabled="{Binding PolygonEditEnable}" 
                          IsChecked="{Binding PolygonTypeChecked}"
                          ToolTip="지도에서 점 추가 (단축키: E)"/>

                    <!--<TextBlock Grid.Row="0" Grid.Column="0" Text=" 위도" Style="{StaticResource NormalTextBlock}" Foreground="White" Margin="25,0,0,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PolygonLatControl, StringFormat=F5, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource NormalTextBox}" IsEnabled="{Binding PolygonButton1Enable}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="°" Style="{StaticResource NormalTextBlock}" Foreground="White"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text=" 경도" Style="{StaticResource NormalTextBlock}" Foreground="White" Margin="25,0,0,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PolygonLonControl, StringFormat=F5, UpdateSourceTrigger=PropertyChanged}" 
                     Style="{StaticResource NormalTextBox}" IsEnabled="{Binding PolygonButton1Enable}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="°" Style="{StaticResource NormalTextBlock}" Foreground="White"/>-->

                    <!--<TextBlock Grid.Row="0" Grid.Column="0" Text="고도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" Margin="30,0,0,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PolygonAltControl}"
                     Style="{StaticResource NormalTextBox}" IsEnabled="{Binding PolygonButton1Enable}" Width="100"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>-->

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hole" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" Margin="30,0,0,0"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource HudComboBoxStyle}" Margin="10,0,0,0" Width="135" Height="25" FontSize="10"
                      SelectedIndex="{Binding IsHoleIndex}" IsEnabled="{Binding PolygonButton1Enable}">
                        <ComboBoxItem Content="해당 영역 제외" />
                        <ComboBoxItem Content="해당 영역 포함" />
                    </ComboBox>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
                        <Button Content="{Binding PolygonButton1Text}" Command="{Binding PolygonButton1Command}" IsEnabled="{Binding PolygonButton1Enable}"
                        Style="{StaticResource HudButtonStyle}" Width="60" FontSize="13" Margin="0,0,5,0"/>

                        <Button Content="{Binding PolygonButton2Text}" Command="{Binding PolygonButton2Command}" IsEnabled="{Binding PolygonButton2Enable}"
                        Style="{StaticResource HudButtonStyle}" Width="60" FontSize="13"  Margin="0,0,5,0"/>

                        <Button Content="{Binding PolygonButton3Text}" Command="{Binding PolygonButton3Command}" IsEnabled="{Binding PolygonButton3Enable}"
                        Style="{StaticResource HudButtonStyle}" Width="60" FontSize="13" />
                    </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>



            <dxg:GridControl
 
        x:Name="InputMissionGrid"
        ItemsSource="{Binding inputMissionList}"
        SelectedItem="{Binding SelectedinputMissionItem}"
        AutoGenerateColumns="None"
        Height="295"
        VerticalAlignment="Top"
        Grid.Row="1"
        Grid.Column="1">

                <dxg:GridControl.View>
                    <dxg:TableView
            ShowGroupPanel="False"
            AllowResizing="False"
            HorizontalScrollbarVisibility="Hidden"
            AllowEditing="True"
            AllowColumnFiltering="False"
            AllowColumnMoving="False"
            AllowSorting="False"
            NavigationStyle="Cell"
            EditorShowMode="MouseDown"
            EnableImmediatePosting="True"
            FocusedRowHandle="{Binding SelectedinputMissionListIndex}"
            ShowIndicator="False">
               
                    </dxg:TableView>
                </dxg:GridControl.View>

                <dxg:GridControl.Columns>
                    <dxg:GridColumn
            FieldName="InputMissionID"
            Header="임무 ID"
            Width="90"
            HorizontalHeaderContentAlignment="Center"
                        ReadOnly="True">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>

                    <dxg:GridColumn
            FieldName="SequenceNumber"
            Header="순서"
            Width="50"
                        HorizontalHeaderContentAlignment="Center"
                        ReadOnly="True"/>

                    
                    <dxg:GridColumn
      FieldName="InputMissionType"
      Header="임무 유형"
      Width="150"
      HorizontalHeaderContentAlignment="Center">
                        <!-- 평상시 보여줄 템플릿 -->
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock
            Text="{Binding Value, Converter={StaticResource UnitMissionTypeToStringConverter}}"
            TextAlignment="Center"
            VerticalAlignment="Center"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                        <!-- 클릭해서 편집할 때도 동일한 템플릿 사용 -->
                        <dxg:GridColumn.CellEditTemplate>
                            <DataTemplate>
                                <TextBlock
            Text="{Binding Value, Converter={StaticResource UnitMissionTypeToStringConverter}}"
            TextAlignment="Center"
            VerticalAlignment="Center"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellEditTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn FieldName="RegionType" Header="지점 / 지역 정보" Width="107" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value, Converter={StaticResource RegionTypeToStringConverter}}" TextAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>
                        <dxg:GridColumn.CellEditTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value, Converter={StaticResource RegionTypeToStringConverter}}" TextAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellEditTemplate>
                    </dxg:GridColumn>


                    <!--<dxg:GridColumn FieldName="IsDisplay"
                Header="전시"
                Width="70"
                HorizontalHeaderContentAlignment="Center">

                        <dxg:GridColumn.CellDisplayTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Data.IsDisplay}" 
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False"
                                          Focusable="False"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellDisplayTemplate>

                        <dxg:GridColumn.CellEditTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Data.IsDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                                          Focusable="False"/>
                            </DataTemplate>
                        </dxg:GridColumn.CellEditTemplate>
                    </dxg:GridColumn>-->

                    <dxg:GridColumn FieldName="IsDisplay"
                Header="전시"
                Width="70"
                HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.EditSettings>
                            <dxe:CheckEditSettings 
            IsThreeState="False"
            HorizontalContentAlignment="Center"/>
                        </dxg:GridColumn.EditSettings>
                    </dxg:GridColumn>


                </dxg:GridControl.Columns>
            </dxg:GridControl>

            <Button Grid.Column="1" Grid.Row="2" Content="{Binding Button1Text}" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding Button1Enable}" Height="30" Width="80" HorizontalAlignment="Left" Margin="0,0,0,0">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseDown">
                        <i:InvokeCommandAction Command="{Binding Button1Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>

            <Button Grid.Column="1" Grid.Row="2" Content="{Binding Button2Text}" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding Button2Enable}" Width="80" HorizontalAlignment="Left" Margin="85,0,0,0">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseDown">
                        <i:InvokeCommandAction Command="{Binding Button2Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>

            <Button Grid.Column="1" Grid.Row="2" Content="{Binding Button3Text}" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding Button3Enable}" Width="80" HorizontalAlignment="Left" Margin="170,0,0,0">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseDown">
                        <i:InvokeCommandAction Command="{Binding Button3Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>

        </Grid>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Column="1" Grid.Row="1" Text="협업기저임무 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
            <TextBox Grid.Column="2" Grid.Row="1" Width="100" Text="{Binding Name_Control,UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" HorizontalAlignment="Center" IsEnabled="False"/>

            <TextBlock Grid.Column="3" Grid.Row="1" Text="임무 유형" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
            <ComboBox Grid.Column="4" Grid.Row="1" Style="{StaticResource HudComboBoxStyle}" Height="25" Width="150" FontSize="10" Margin="{StaticResource UIELEMENT_MARGIN}" IsEnabled="{Binding EditEnable}" SelectedIndex="{Binding MissionTypeIndex}">
                <ComboBoxItem Content="N/A" />
                <ComboBoxItem Content="협업기동임무" />
                <ComboBoxItem Content="협업수색공격임무" />
                <ComboBoxItem Content="협업경계임무" />
                <ComboBoxItem Content="협업공중부대엄호임무" />
                <ComboBoxItem Content="협업지상부대엄호임무" />
                <ComboBoxItem Content="협업도심수색공격임무" />
                <ComboBoxItem Content="Reserved 1" />
                <ComboBoxItem Content="Reserved 2" />
                <ComboBoxItem Content="Reserved 3" />
            </ComboBox>

            <TextBlock Grid.Column="1" Grid.Row="2" Text="임무지역 순서" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
            <TextBox Grid.Column="2" Grid.Row="2" Width="100" Text="{Binding Order_Control, TargetNullValue=0, FallbackValue=0}" Style="{StaticResource NormalTextBox}" HorizontalAlignment="Center" IsEnabled="{Binding EditEnable}" ToolTip="저장 시 중복되면 기존 순번이 밀림"/>
            <!--<dxe:TextEdit Grid.Column="2" Grid.Row="2" Text="{Binding Order_Control}" 
              IsReadOnly="True" 
              Background="LightGray" 

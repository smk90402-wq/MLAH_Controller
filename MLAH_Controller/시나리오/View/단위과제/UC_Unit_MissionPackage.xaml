<UserControl x:Class="MLAH_Controller.UC_Unit_MissionPackage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        dx:ThemeManager.ThemeName="Win11Dark"
        Height="1160" Width="520"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"
        >

    <UserControl.DataContext>
        <Binding Source="{x:Static local:ViewModel_UC_Unit_MissionPackage.SingletonInstance}"/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <local:TypeToStringConverter x:Key="TypeToStringConverter" />
        <local:MissionTypeToStringConverter x:Key="MissionTypeToStringConverter" />

        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="BorderBrush" Value="{StaticResource SciFi_Border}"/>
            <Setter Property="Foreground" Value="{StaticResource SciFi_Cyan}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            
            <RowDefinition Height="210"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="210"/>
        </Grid.RowDefinitions>

        <!--<TextBlock Text="비행참조정보 패키지 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}" Margin="10,20,0,0"/>
        <TextBlock Text="1" Style="{StaticResource NormalTextBlock}"  Margin="160,20,0,0"/>-->

        <!--<GroupBox Grid.ColumnSpan="2" Grid.RowSpan="7" Header="비행참조정보 패키지" Foreground="{StaticResource SciFi_Cyan}" BorderBrush="White" Margin="0,0,0,5"/>-->
        <GroupBox Grid.ColumnSpan="2" Grid.Row="1" Header="무인기 통제권 획득 위치 (= 임무시작 초기 위치)" Margin="10,10,10,10" Height="190" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

             
                <dxg:GridControl ItemsSource="{Binding TakeOverItemSource}" Background="{StaticResource MLAH_COLOR_POPUP_DLG_BG_Brush}"
                 SelectedItem="{Binding TakeOverSelectedItem}"
                 AutoGenerateColumns="None" 
                 Height="150"
                 VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
            AllowResizing="False"
            HorizontalScrollbarVisibility="Hidden"
            AllowEditing="False"
            AllowColumnFiltering="False"
            AllowColumnMoving="False"
            AllowSorting="False"
            NavigationStyle="Cell"
            EditorShowMode="MouseDown"
            EnableImmediatePosting="False"
            ShowIndicator="False"       
            FocusedRowHandle ="{Binding TakeOverSelectedIndex}">
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>

                        <dxg:GridColumn FieldName="AircraftID" Header="ID" Width="30" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="CoordinateList.Latitude" Header="위도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="CoordinateList.Longitude" Header="경도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="CoordinateList.Altitude" Header="고도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                    </dxg:GridControl.Columns>
                </dxg:GridControl>

                <Grid Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Column="0" Grid.Row="0" Style="{StaticResource HudToggleIcon_25}" IsEnabled="{Binding TakeOverCheckEditEnable}"  HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding TakeOverChecked}" />

                    <TextBlock Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Text="무인기 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="위도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="경도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="3" Text="고도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="{Binding TakeOverButton1Text}"  Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding TakeOverButton1Enable}"  Width="50" HorizontalAlignment="Left">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding TakeOverButton1Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="{Binding TakeOverButton2Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding TakeOverButton2Enable}"  Width="50" HorizontalAlignment="Left" Margin="55,0,0,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding TakeOverButton2Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="{Binding TakeOverButton3Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding TakeOverButton3Enable}"  Width="50" HorizontalAlignment="Left" Margin="110,0,0,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding TakeOverButton3Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <ComboBox Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="0" Style="{StaticResource HudComboBoxStyle}" Height="25" Width="70" Margin="30,0,0,0" IsEnabled="{Binding TakeOverEditEnable}" SelectedIndex="{Binding TakeOverUAVIDIndex}">
                        <ComboBoxItem Content="4 : UAV#1" />
                        <ComboBoxItem Content="5 : UAV#2" />
                        <ComboBoxItem Content="6 : UAV#3" />
                    </ComboBox>

                    <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding TakeOverLAT}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding TakeOverEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="1" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBox Grid.Column="2" Grid.Row="2" Text="{Binding TakeOverLON}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding TakeOverEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="2" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBox Grid.Column="2" Grid.Row="3" Text="{Binding TakeOverALT}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding TakeOverEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="3" Text=" m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.ColumnSpan="2" Grid.Row="2" Header="무인기 통제권 인계 위치 (= 임무종료 위치)" Margin="10,10,10,10" Height="190" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--<DataGrid Grid.Column="0" Style="{StaticResource NormalDataGrid}" ItemsSource="{Binding HandOverItemSource}"  SelectedIndex="{Binding HandOverSelectedIndex}" Height="150" VerticalAlignment="Top" HorizontalScrollBarVisibility="Hidden" 
                  AlternationCount="10000" >
                    --><!--GridLinesVisibility="All" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"--><!--
                    <DataGrid.Columns>
                        --><!-- 순번 컬럼 --><!--
                        <DataGridTextColumn Header="순번" Width="30" IsReadOnly="True">
                            <DataGridTextColumn.Binding>
                                <Binding Path="(ItemsControl.AlternationIndex)" RelativeSource="{RelativeSource AncestorType=DataGridRow}" Converter="{StaticResource IndexPlusOneConverter}" />
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>

                        --><!-- 나머지 실제 데이터 컬럼들 --><!--
                        <DataGridTextColumn Header="ID" Width="30" IsReadOnly="True" Binding="{Binding AircraftID}"/>
                        <DataGridTextColumn Header="위도" Width="70" IsReadOnly="True" Binding="{Binding CoordinateList.Latitude}"/>
                        <DataGridTextColumn Header="경도" Width="70" IsReadOnly="True" Binding="{Binding CoordinateList.Longitude}"/>
                        <DataGridTextColumn Header="고도" Width="70" IsReadOnly="True" Binding="{Binding CoordinateList.Altitude}"/>
                    </DataGrid.Columns>
                    <i:Interaction.Behaviors>
                        <local:BindableSelectedItemBehaviorForDataGrid SelectedItem="{Binding HandOverSelectedItem,Mode=TwoWay}" />
                    </i:Interaction.Behaviors>
                </DataGrid>-->

                <dxg:GridControl ItemsSource="{Binding HandOverItemSource}" Background="{StaticResource MLAH_COLOR_POPUP_DLG_BG_Brush}"
     SelectedItem="{Binding HandOverSelectedItem}"
     AutoGenerateColumns="None" 
     Height="150"
     VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False"
AllowResizing="False"
HorizontalScrollbarVisibility="Hidden"
AllowEditing="False"
AllowColumnFiltering="False"
AllowColumnMoving="False"
AllowSorting="False"
NavigationStyle="Cell"
EditorShowMode="MouseDown"
EnableImmediatePosting="False"
ShowIndicator="False"       
FocusedRowHandle ="{Binding HandOverSelectedIndex}">
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>

                        <dxg:GridColumn FieldName="AircraftID" Header="ID" Width="30" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="CoordinateList.Latitude" Header="위도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="CoordinateList.Longitude" Header="경도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center" MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="CoordinateList.Altitude" Header="고도" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                    </dxg:GridControl.Columns>
                </dxg:GridControl>

                <Grid Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Column="0" Grid.Row="0" Style="{StaticResource HudToggleIcon_25}" IsEnabled="{Binding HandOverCheckEditEnable}"  HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding HandOverChecked}" />

                    <TextBlock Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Text="무인기 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="위도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="경도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="3" Text="고도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="{Binding HandOverButton1Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding HandOverButton1Enable}"  Width="50" HorizontalAlignment="Left">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding HandOverButton1Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="{Binding HandOverButton2Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding HandOverButton2Enable}" Width="50" HorizontalAlignment="Left" Margin="55,0,0,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding HandOverButton2Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="4" Grid.ColumnSpan="3" Content="{Binding HandOverButton3Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding HandOverButton3Enable}" Width="50" HorizontalAlignment="Left" Margin="110,0,0,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding HandOverButton3Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <ComboBox Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="0" Style="{StaticResource HudComboBoxStyle}" Height="25" Width="70" Margin="30,0,0,0" IsEnabled="{Binding HandOverEditEnable}" SelectedIndex="{Binding HandOverUAVIDIndex}">
                        <ComboBoxItem Content="4 : UAV#1" />
                        <ComboBoxItem Content="5 : UAV#2" />
                        <ComboBoxItem Content="6 : UAV#3" />
                    </ComboBox>

                    <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding HandOverLAT}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding HandOverEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="1" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBox Grid.Column="2" Grid.Row="2" Text="{Binding HandOverLON}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding HandOverEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="2" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBox Grid.Column="2" Grid.Row="3" Text="{Binding HandOverALT}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding HandOverEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="3" Text=" m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.ColumnSpan="2" Grid.Row="3" Header="무인기 귀환 위치" Margin="10,10,10,10" Height="190" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>



                <dxg:GridControl Grid.Column="0"  Background="{StaticResource MLAH_COLOR_POPUP_DLG_BG_Brush}"
                         ItemsSource="{Binding RTBItemSource}" 
                         SelectedItem="{Binding RTBSelectedItem}"
                         Height="150" 
                         VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" 
                               AllowEditing="False" 
                               NavigationStyle="Row" 
                               ShowIndicator="False"/>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>
                        <!--<dxg:GridColumn Header="순번" Width="40" FixedWidth="True" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RowData.RowHandle.Value, Converter={StaticResource IndexPlusOneConverter}}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>-->

                        <dxg:GridColumn FieldName="Latitude" Header="위도" Width="*" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Longitude" Header="경도" Width="*" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings MaskType="Numeric" Mask="F5" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="Altitude" Header="고도" Width="*" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Column="0" Grid.Row="0" Style="{StaticResource HudToggleIcon_25}" IsEnabled="{Binding RTBCheckEditEnable}"  HorizontalAlignment="Center" VerticalAlignment="Center" IsChecked="{Binding RTBChecked}" />

                    <!--<TextBlock Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Text="무인기 ID" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>-->
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="위도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="경도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="고도" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <Button Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Content="{Binding RTBButton1Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding RTBButton1Enable}"  Width="50" HorizontalAlignment="Left">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding RTBButton1Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Content="{Binding RTBButton2Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding RTBButton2Enable}" Width="50" HorizontalAlignment="Left" Margin="55,0,0,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding RTBButton2Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="3" Content="{Binding RTBButton3Text}" Height="30" Style="{StaticResource HudButtonStyle}" IsEnabled="{Binding RTBButton3Enable}"  Width="50" HorizontalAlignment="Left" Margin="110,0,0,0">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseDown">
                                <i:InvokeCommandAction Command="{Binding RTBButton3Command}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=UserControl}}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <!--<ComboBox Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="0" Style="{StaticResource HudComboBoxStyle}" Height="25" Width="70" Margin="30,0,0,0" IsEnabled="{Binding RTBEditEnable}" SelectedIndex="{Binding RTBUAVIDIndex}">
                        <ComboBoxItem Content="4 : UAV#1" />
                        <ComboBoxItem Content="5 : UAV#2" />
                        <ComboBoxItem Content="6 : UAV#3" />
                    </ComboBox>-->

                    <TextBox Grid.Column="2" Grid.Row="0" Text="{Binding RTBLAT, StringFormat=F5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding RTBEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="0" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBox Grid.Column="2" Grid.Row="1" Text="{Binding RTBLON, StringFormat=F5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding RTBEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="1" Text=" °" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>

                    <TextBox Grid.Column="2" Grid.Row="2" Text="{Binding RTBALT}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding RTBEditEnable}"/>
                    <TextBlock Grid.Column="3" Grid.Row="2" Text=" m" Style="{StaticResource NormalTextBlock}" Foreground="{StaticResource SciFi_Cyan}"/>
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.ColumnSpan="2" Grid.Row="4" Header="비행가능구역" BorderBrush="{StaticResource SciFi_Border}" Foreground="{StaticResource SciFi_Cyan}" Margin="10,10,10,10" Height="190" VerticalAlignment="Top" IsEnabled="True">
          

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <dxg:GridControl Grid.Column="0"
                         ItemsSource="{Binding FlightAreaItemSource}"
                         SelectedItem="{Binding FlightAreaSelectedItem}"
                         Height="150"
                         Background="{StaticResource MLAH_COLOR_POPUP_DLG_BG_Brush}"
                         VerticalAlignment="Top">

                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" 
                               AllowEditing="False" 
                               NavigationStyle="Cell"
                                       AllowSorting="False"
                               ShowIndicator="False"
                                       AllowColumnFiltering="False"
                               AllowMasterDetail="True"/>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>
                        <!--<dxg:GridColumn Header="ID" FieldName="UI_ID" Width="30" FixedWidth="True" AllowEditing="False" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>-->

                        <dxg:GridColumn Header="하한(m)" FieldName="LowerLimit" Width="*" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings MaskType="Numeric" Mask="D" MaskUseAsDisplayFormat="True" HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn Header="상한(m)" FieldName="UpperLimit" Width="*" HorizontalHeaderContentAlignment="Center">

<Window x:Class="MLAH_Controller.View_AbnormalZone_PopUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Height="320" Width="950" WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  AllowsTransparency="True" WindowStartupLocation="CenterScreen"
        >

    <Window.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="CustomTitleBarTemplate" TargetType="{x:Type Window}">
                <Border CornerRadius="1" BorderBrush="{StaticResource COLOR_GRAY102_Brush}" BorderThickness="2" Background="{StaticResource MLAH_COLOR_BG_Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                         <!--사용자 지정 타이틀 바-->
                        <Border Background="#4d4dff" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                            <TextBlock Text="비정상 구역" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White"/>
                        </Border>

                         <!--콘텐츠 표시 영역--> 
                        <AdornerDecorator Grid.Row="1"  >
                            <ContentPresenter/>
                        </AdornerDecorator>
                    </Grid>
                </Border>
            </ControlTemplate>
            <Style BasedOn="{StaticResource NormalTextBlock}" TargetType="TextBlock"/>
        </ResourceDictionary>
    </Window.Resources>
     <!--리소스 정의 끝--> 

     <!--컨트롤 템플릿 적용--> 
    <Window.Template>
        <StaticResource ResourceKey="CustomTitleBarTemplate"/>
    </Window.Template>

    <Window.DataContext>
        <Binding Source="{x:Static local:ViewModel_AbnormalZone_PopUp.SingletonInstance}"/>
    </Window.DataContext>

    <!--전체 그리드-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>


        <DataGrid Style="{StaticResource NormalDataGrid}" ItemsSource="{Binding DataGridAbnormalZones}" IsEnabled="{Binding AbnormalZonesDataGridEnable}" SelectedIndex="{Binding AbnormalZoneDataGridSelectedIndex}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="구역 유형" Width="100" IsReadOnly="True" Binding="{Binding AbnormalZoneTypeText}"/>
                <DataGridTextColumn Header="시작 위도 (°)" Width="100" IsReadOnly="True" Binding="{Binding AbnormalZoneStartLat, StringFormat=F5}"/>
                <DataGridTextColumn Header="시작 경도 (°)" Width="100" IsReadOnly="True" Binding="{Binding AbnormalZoneStartLon, StringFormat=F5}"/>
                <DataGridTextColumn Header="끝 위도 (°)" Width="100" IsReadOnly="True" Binding="{Binding AbnormalZoneEndLat, StringFormat=F5}"/>
                <DataGridTextColumn Header="끝 경도 (°)" Width="100" IsReadOnly="True" Binding="{Binding AbnormalZoneEndLon, StringFormat=F5}"/>
                <DataGridTextColumn Header="너비 (km²)" Width="100" IsReadOnly="True" Binding="{Binding AbnormalZoneRectArea, StringFormat=F5}"/>
            </DataGrid.Columns>
            <i:Interaction.Behaviors>
                <local:BindableSelectedItemBehaviorForDataGrid SelectedItem="{Binding SelectedDataGridAbnormalZone}" />
            </i:Interaction.Behaviors>
        </DataGrid>


        <Grid Grid.Column="2" Background="{StaticResource MLAH_COLOR_BG_Brush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            
            <TextBlock Grid.Row="0" Text="구역 유형" Foreground="White"/>
            <TextBlock Grid.Row="1" Text="시작 위도 (°)" Foreground="White"/>
            <TextBlock Grid.Row="2" Text="시작 경도 (°)" Foreground="White"/>
            <TextBlock Grid.Row="3" Text="시작 고도 (m)" Foreground="White"/>
            <TextBlock Grid.Row="4" Text="끝 위도 (°)" Foreground="White"/>
            <TextBlock Grid.Row="5" Text="끝 경도 (°)" Foreground="White"/>
            <TextBlock Grid.Row="6" Text="끝 고도 (m)" Foreground="White"/>
            <TextBlock Grid.Row="7" Text="너비 (km²)" Foreground="White"/>
            
        </Grid>

        <Grid Grid.Column="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <ComboBox Grid.Row="0" Style="{StaticResource NormalComboBox}" Height="25" Width="115" Margin="{StaticResource UIELEMENT_MARGIN}" IsEnabled="{Binding EditEnable}" SelectedIndex="{Binding AbnormalZoneTypeIndex}">
                <ComboBoxItem Content="전파 방해" />
                <ComboBoxItem Content="위험 구역"/>
                <ComboBoxItem Content="No Statement"/>
            </ComboBox>

            <TextBox Grid.Row="1" Text="{Binding AbnormalZoneRectStartLat, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            <TextBox Grid.Row="2" Text="{Binding AbnormalZoneRectStartLon, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            <TextBox Grid.Row="3" Text="{Binding AbnormalZoneRectStartAlt, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            <TextBox Grid.Row="4" Text="{Binding AbnormalZoneRectEndLat, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            <TextBox Grid.Row="5" Text="{Binding AbnormalZoneRectEndLon, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            <TextBox Grid.Row="6" Text="{Binding AbnormalZoneRectEndAlt, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            <TextBox Grid.Row="7" Text="{Binding AbnormalZoneRectArea, UpdateSourceTrigger=PropertyChanged, StringFormat=N5}" Style="{StaticResource NormalTextBox}" IsEnabled="{Binding EditEnable}"/>
            
        </Grid>

        <ToggleButton Grid.Column="4" Grid.Row="0" Style="{StaticResource POSSelectToggleButtonStyle}" IsEnabled="{Binding EditEnable}" HorizontalAlignment="Center" IsChecked="{Binding AbnormalZoneSelectChecked}" Margin="0,0,0,145"/>

        <Button Grid.Column="0" Grid.Row="1" Width="100" Content="{Binding AddButtonText}" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" IsEnabled="{Binding AddButtonEnable}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding AddCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
        
        <Button Grid.Column="0" Grid.Row="1" Width="100" Content="{Binding EditButtonText}" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" Margin="105,0,0,0" IsEnabled="{Binding EditButtonEnable}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding EditCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
        
        <Button Grid.Column="0" Grid.Row="1" Width="100" Content="{Binding DeleteButtonText}" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" Margin="210,0,0,0" IsEnabled="{Binding DeleteButtonEnable}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding DeleteCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>

        <Button Grid.Column="3" Grid.ColumnSpan="2" Grid.Row="1" Width="100" Content="닫기" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Right">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
    </Grid>



</Window>

                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <ComboBox Grid.Row="0" Style="{StaticResource HudComboBoxStyle}" Height="25" Margin="{StaticResource UIELEMENT_MARGIN}" SelectedIndex="{Binding BattlefieldArea}"
                      IsEnabled="{Binding Source={x:Static local:ViewModel_ScenarioView.SingletonInstance}, Path=IsSimPlayingRev}">
                <ComboBoxItem Content="No Statement" Visibility="Collapsed"/>

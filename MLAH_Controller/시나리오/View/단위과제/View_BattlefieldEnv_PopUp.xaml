        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>


        <Grid Grid.Column="1" Background="{StaticResource MLAH_COLOR_BG_Brush}">

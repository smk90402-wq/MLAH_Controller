<Window x:Class="MLAH_Controller.View_BattlefieldEnv_PopUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Height="250" Width="310" WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  AllowsTransparency="True" WindowStartupLocation="CenterScreen"
        >

    <Window.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="CustomTitleBarTemplate" TargetType="{x:Type Window}">
                <Border CornerRadius="1" BorderBrush="{StaticResource COLOR_GRAY102_Brush}" BorderThickness="2" Background="{StaticResource MLAH_COLOR_BG_Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                         <!--사용자 지정 타이틀 바-->
                        <Border Background="#4d4dff" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                            <TextBlock Text="전장환경 설정" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White"/>
                        </Border>

                         <!--콘텐츠 표시 영역--> 
                        <AdornerDecorator Grid.Row="1"  >
                            <ContentPresenter/>
                        </AdornerDecorator>
                    </Grid>
                </Border>
            </ControlTemplate>
            <Style BasedOn="{StaticResource NormalTextBlock}" TargetType="TextBlock"/>
        </ResourceDictionary>
    </Window.Resources>
     <!--리소스 정의 끝--> 

     <!--컨트롤 템플릿 적용--> 
    <Window.Template>
        <StaticResource ResourceKey="CustomTitleBarTemplate"/>
    </Window.Template>

    <Window.DataContext>
        <Binding Source="{x:Static local:ViewModel_BattlefieldEnv_PopUp.SingletonInstance}"/>
    </Window.DataContext>

    <!--전체 그리드-->

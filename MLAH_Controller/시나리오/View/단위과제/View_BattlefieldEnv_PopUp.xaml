                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="모의 지역" Foreground="White"/>
            <TextBlock Grid.Row="1" Text="시간" Foreground="White"/>
            <TextBlock Grid.Row="2" Text="계절" Foreground="White"/>
            <TextBlock Grid.Row="3" Text="날씨" Foreground="White"/>
            <TextBlock Grid.Row="4" Text="구름" Foreground="White"/>
        </Grid>

        <Grid Grid.Column="2">

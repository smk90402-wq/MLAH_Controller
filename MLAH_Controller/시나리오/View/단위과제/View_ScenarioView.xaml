<UserControl x:Class="MLAH_Controller.View_ScenarioView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        dx:ThemeManager.ThemeName="Win11Dark"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d" 
        d:DataContext="{d:DesignInstance Type=local:ViewModel_ScenarioView, IsDesignTimeCreatable=True}"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Height="1440" Width="2560" 
        Background="{StaticResource MLAH_COLOR_BG_Brush}" 
        >
    <UserControl.Resources>
        <local:UnitObjectDisplayConverter x:Key="UnitObjectDisplayConverter" />

   

        <Style x:Key="SciFiTextBlock_ScenarioView_Style" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
            <!--<Setter Property="FontSize" Value="18"/>-->
            <Setter Property="FontWeight" Value="Bold"/>
            <!--<Setter Property="VerticalAlignment" Value="Center"/>-->

            <Setter Property="Foreground" Value="#E0FFFF"/>

            <!--<Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00F0FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                </Setter.Value>
            </Setter>-->

            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SciFi_Cyan}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="RibbonGroupBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SciFi_PanelBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SciFi_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="5,10"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </UserControl.Resources>
    
    <Grid x:Name="LayoutRoot">
        <!--전체 그리드-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="550"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="450"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="770"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7" Background="#CC080A10" BorderBrush="{StaticResource SciFi_Border}" BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource HighEndSciFiIconButtonStyle}" />
                    </StackPanel.Resources>
                    <Border Style="{StaticResource RibbonGroupBorder}">
                        <StackPanel Orientation="Horizontal">
                            <Button Tag="시나리오&#x0a;생성" IsEnabled="{Binding IsSimPlayingRev}" Content="{StaticResource Icon_Add_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ScenarioAddCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <Button Tag="시나리오&#x0a;불러오기" IsEnabled="{Binding IsSimPlayingRev}" Content="{StaticResource Icon_Open_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ScenarioOpenCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <Button Tag="시나리오&#x0a;저장" IsEnabled="{Binding IsSimPlayingRev}" Content="{StaticResource Icon_Save_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ScenarioSaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                            <Button Tag="다른 이름으로&#x0a;저장" IsEnabled="{Binding IsSimPlayingRev}" Content="{StaticResource Icon_Save_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ScenarioSaveAsCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroupBorder}" Width="250">
                        <Grid VerticalAlignment="Center" Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="시나리오 이름 : " Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SceneFileName}" Style="{StaticResource InfoValueStyle}" ToolTip="{Binding SceneFileName}"/>

                            <Separator Grid.Row="1" Grid.ColumnSpan="2" Background="#33FFFFFF" Margin="0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="설명 : " Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SceneFileDescription}" Style="{StaticResource InfoValueStyle}" ToolTip="{Binding SceneFileDescription}" Margin="-45,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RibbonGroupBorder}">
                        <Grid Margin="10,5" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="작전 유형" Style="{StaticResource InfoLabelStyle}" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="2" Style="{StaticResource HudComboBoxStyle}" 
                                      Height="25" FontSize="12" Width="180" VerticalContentAlignment="Center" Padding="5,0"
                                      IsEnabled="{Binding SimPlayButtonEnable}" SelectedIndex="{Binding PackageTypeComboIndex}">
                                <ComboBoxItem Content="N/A" />
                                <ComboBoxItem Content="대기갑항공타격작전" />
                                <ComboBoxItem Content="지상작전부대 기동여건보장" />
                                <ComboBoxItem Content="공중강습작전부대 엄호" />
                                <ComboBoxItem Content="항공지원작전-중요시설 방호" />
                                <ComboBoxItem Content="도시지역 작전" />
                            </ComboBox>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="센서 유형" Style="{StaticResource InfoLabelStyle}" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="2" Width="180" Style="{StaticResource HudComboBoxStyle}" 
                                      Height="25" FontSize="12" VerticalContentAlignment="Center" Padding="5,0"
                                      IsEnabled="{Binding SimPlayButtonEnable}" SelectedIndex="{Binding SensorTypeComboIndex}">
                                <ComboBoxItem Content="N/A" />
                                <ComboBoxItem Content="주간 (EO)" />
                                <ComboBoxItem Content="야간 (IR)" />
                            </ComboBox>
                        </Grid>
                    </Border>

        
                    <Border Style="{StaticResource RibbonGroupBorder}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <Button Style="{StaticResource RibbonButtonStyle}" Tag="모의 시작" IsEnabled="{Binding IsSimPlayingRev}">
                                <Path Data="{StaticResource Icon_Play_HQ}" Width="28" Height="28" Fill="{StaticResource SciFi_Cyan}" Stretch="Uniform"/>
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ScenarioPlayCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                            <Border Width="1" Background="#33FFFFFF" Margin="5,10"/>

                            <Button Style="{StaticResource RibbonButtonStyle}" Tag="일시 정지" IsEnabled="False">
                                <Path Data="{StaticResource Icon_Pause_HQ}" Width="28" Height="28" Fill="{StaticResource SciFi_Cyan}" Stretch="Uniform"/>
                            </Button>

                            <Border Width="1" Background="#33FFFFFF" Margin="5,10"/>

                            <Button Style="{StaticResource RibbonButtonStyle}" Tag="모의 종료" IsEnabled="{Binding IsSimPlaying}">
                                <Path Data="{StaticResource Icon_Stop_HQ}" Width="28" Height="28" Fill="{StaticResource SciFi_Cyan}" Stretch="Uniform"/>
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ScenarioStopCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroupBorder}" Width="150">
                        <Grid VerticalAlignment="Center" Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="상태 : " Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding SceneStatus}" Style="{StaticResource InfoValueStyle}" Foreground="{StaticResource SciFi_Cyan}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                <TextBlock Text="시간 : " Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding SceneTime, StringFormat={}{0:hh\\:mm\\:ss}}" Style="{StaticResource InfoValueStyle}" FontFamily="Consolas"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource RibbonGroupBorder}">
                        <StackPanel Orientation="Horizontal">
                            <Button Tag="동적상황&#x0a;부여" Content="{StaticResource Icon_Dynamic_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ObjectSetCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                            <Line X1="0" Y1="10" X2="0" Y2="60" Stroke="#33FFFFFF" Margin="5,0"/>

                            <Button Tag="전장환경&#x0a;설정" IsEnabled="True" Content="{StaticResource Icon_Weather_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding BattlefieldEnvCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                            <Line X1="0" Y1="10" X2="0" Y2="60" Stroke="#33FFFFFF" Margin="5,0"/>

                            <!--<Button Tag="UDP&#x0a;모니터링" IsEnabled="False" Content="{StaticResource Icon_Monitor_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding UDPMonitoringCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>-->
                            <Button Tag="gRPC&#x0a;모니터링" Content="{StaticResource Icon_Network_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding MonitoringCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>

                            <Line X1="0" Y1="10" X2="0" Y2="60" Stroke="#33FFFFFF" Margin="5,0"/>

                            <Button Tag="메인&#x0a;화면" Content="{StaticResource Icon_Home_HQ}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseDown">
                                        <i:InvokeCommandAction Command="{Binding ReturnToMainCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroupBorder}" Width="150">
                        <Grid VerticalAlignment="Center" Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                       Text="복합협업 복잡도" 
                                       FontSize="17"
                                       Style="{StaticResource InfoLabelStyle}" 
                                       HorizontalAlignment="Center"
                                       Foreground="#AAAAAA"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ScenarioComplexity}" 
                                           Style="{StaticResource SciFiTextBlock_ScenarioView_Style}"
                                           Foreground="{Binding ComplexityColor}"
                                           FontSize="24"
                                           VerticalAlignment="Bottom">
                                </TextBlock>

                                <TextBlock Text=" %" 
                                           Style="{StaticResource InfoValueStyle}" 
                                           Foreground="{Binding ComplexityColor}"
                                           FontSize="14"
                                           Margin="2,0,0,3"
                                           VerticalAlignment="Bottom"/>
                            </StackPanel>

                            <!--<ProgressBar Grid.Row="4" 
                                         Minimum="0" Maximum="100" 
                                         Value="{Binding ScenarioComplexity}"
                                         Height="6"
                                         Background="#20FFFFFF"
                                         BorderThickness="0"
                                         Foreground="{Binding ComplexityColor}">
                                <ProgressBar.Effect>
                                    <DropShadowEffect Color="#00F0FF" BlurRadius="4" ShadowDepth="0" Opacity="0.3"/>
                                </ProgressBar.Effect>
                            </ProgressBar>-->
                        </Grid>
                    </Border>



                    <Border Grid.Column="2" Background="#20000000" CornerRadius="3" Padding="5" VerticalAlignment="Center">
                        <Grid Margin="5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">

                                <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                    <TextBlock Text="모의 자동화" 
                           Style="{StaticResource InfoLabelStyle}" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"/>

                                    <Border DockPanel.Dock="Right"
                        Background="{Binding AutomationStatusBrush}"
                        CornerRadius="3"
                        Padding="5,1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AutomationStatusText}"
                               Foreground="White"
                               FontSize="9"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                                    </Border>
                                </DockPanel>

                                <CheckBox Content="Force Start (강제 시작)" 
                      IsChecked="{Binding IsForceStart}"
                      Foreground="White" FontSize="10" Margin="0,2">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>

                                <UniformGrid Columns="2" Margin="0,5,0,0">
                                    <Button Content="시작" FontSize="10" Margin="0,0,2,0"
                        Style="{StaticResource HudButtonStyle}" Height="25"
                        Command="{Binding StartAutomationCommand}"
                        IsEnabled="{Binding IsAutomationRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                    
                                    <Button Content="중단" FontSize="10" Margin="2,0,0,0"
                        Style="{StaticResource HudButtonStyle}" Height="25"
                        Command="{Binding StopAutomationCommand}"
                        IsEnabled="{Binding IsAutomationRunning}"/>

                                    

                                </UniformGrid>
                                
                            </StackPanel>

                            <ToggleButton x:Name="AgentSelectToggle" 
              Grid.Column="2" 
              FontSize="10" Margin="5,-25,0,0" 
              Style="{StaticResource HudToggleButtonStyle}" 
              Height="25" Width="35" 
              HorizontalAlignment="Left" VerticalAlignment="Top">
                                <ToggleButton.Content>
                                    <TextBlock Text="▽" FontWeight="Bold"/>
                                </ToggleButton.Content>
                            </ToggleButton>

                            <Popup IsOpen="{Binding IsChecked, ElementName=AgentSelectToggle}" 
       StaysOpen="False" 
       PlacementTarget="{Binding ElementName=AgentSelectToggle}" 
       Placement="Bottom"
       AllowsTransparency="True">

                                <Border Background="#F2080A10" 
            BorderBrush="{StaticResource SciFi_Cyan}" 
            BorderThickness="1" 
            CornerRadius="4" 
            Padding="10"
            Margin="0,5,0,0">

                                    <Border.Effect>
                                        <DropShadowEffect Color="#00F0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>

                                    <StackPanel>
                                        <TextBlock Text="제어 대상 선택" Foreground="{StaticResource SciFi_Cyan}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                                        <UniformGrid Columns="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <UniformGrid.Resources>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontSize" Value="11"/>
                                                    <Setter Property="Margin" Value="5"/>
                                                    <Setter Property="LayoutTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </UniformGrid.Resources>

                                            <CheckBox Content="인지" IsChecked="{Binding IsChecked_Recog}"/>
                                            <CheckBox Content="전장1" IsChecked="{Binding IsChecked_Battle1}"/>
                                            <CheckBox Content="전장2" IsChecked="{Binding IsChecked_Battle2}"/>
                                            <CheckBox Content="전장3" IsChecked="{Binding IsChecked_Battle3}"/>
                                            <CheckBox Content="임무" IsChecked="{Binding IsChecked_MissionCtrl}"/>
                                            <CheckBox Content="시현" IsChecked="{Binding IsChecked_Display}"/>
                                            <CheckBox Content="ICD" IsChecked="{Binding IsChecked_Icd}"/>
                                            <CheckBox Content="무인1" IsChecked="{Binding IsChecked_Uav1}"/>
                                            <CheckBox Content="무인2" IsChecked="{Binding IsChecked_Uav2}"/>
                                            <CheckBox Content="무인3" IsChecked="{Binding IsChecked_Uav3}"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <Border Grid.Column="2" Background="#20000000" CornerRadius="3" Padding="5" VerticalAlignment="Center">
                                <Border.Resources>
                                    <Style TargetType="Border" x:Key="StatusBoxStyle">
                                        <Setter Property="Width" Value="35"/>
                                        <Setter Property="Height" Value="30"/>
                                        <Setter Property="CornerRadius" Value="2"/>
                                        <Setter Property="Margin" Value="2"/>
                                        <Setter Property="Background" Value="#333333"/>
                                        <Setter Property="BorderBrush" Value="Gray"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="0">
                                                <Setter Property="Background" Value="#330000"/>
                                                <Setter Property="BorderBrush" Value="#FF5555"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="1">
                                                <Setter Property="Background" Value="#443300"/>
                                                <Setter Property="BorderBrush" Value="#FFFF00"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="2">
                                                <Setter Property="Background" Value="#004400"/>
                                                <Setter Property="BorderBrush" Value="#00FF00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>

                                    <Style TargetType="TextBlock" x:Key="StatusTextStyle">
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Foreground" Value="#AAAAAA"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}" Value="1">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}" Value="2">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Resources>

                                <UniformGrid Columns="6" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding RecogSimStatus}">
                                        <TextBlock Text="인지" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding BattleSim1Status}">
                                        <TextBlock Text="전장1" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding BattleSim2Status}">
                                        <TextBlock Text="전장2" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding BattleSim3Status}">
                                        <TextBlock Text="전장3" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding MissionCtrlStatus}">
                                        <TextBlock Text="임무" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding DisplaySimStatus}">
                                        <TextBlock Text="시현" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>

                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding IcdModuleStatus}">
                                        <TextBlock Text="ICD" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding UavSim1Status}">
                                        <TextBlock Text="무인1" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding UavSim2Status}">
                                        <TextBlock Text="무인2" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <Border Style="{StaticResource StatusBoxStyle}" Tag="{Binding UavSim3Status}">
                                        <TextBlock Text="무인3" Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                    <!--<Border Style="{StaticResource StatusBoxStyle}" Visibility="Hidden"/>-->

                                    <!--<Border Style="{StaticResource StatusBoxStyle}" Background="Transparent" BorderThickness="0">
                                        <Button Content="T" Style="{StaticResource HudButtonStyle}" Command="{Binding StartSimpleAutomationCommand}" Margin="0" Padding="0" Width="35" Height="30"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                                    </Border>-->

                                    <Border Style="{StaticResource StatusBoxStyle}" Background="Transparent" BorderThickness="0">
                                        <Button Content="SW&#x0a;On"
            Style="{StaticResource MiniHudButtonStyle}"  Command="{Binding TurnOnAllAgentsCommand}"
            Margin="0" Padding="0"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                                    </Border>

                                    <Border Style="{StaticResource StatusBoxStyle}" Background="Transparent" BorderThickness="0">
                                        <Button Content="SW&#x0a;Off"
            Style="{StaticResource MiniHudButtonStyle}"  Command="{Binding TurnOffAllAgentsCommand}"
            Margin="0" Padding="0"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                                    </Border>

                                </UniformGrid>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

      

        <Grid Grid.Column="1" Grid.Row="2" Height="380" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <HeaderedContentControl Header="객체 목록" Style="{StaticResource HudGroupStyle}">

                <ListView ItemsSource="{Binding model_UnitScenario.UnitObjectList}" 
                  SelectedIndex="{Binding ListSelectedIndex}"
                  Background="Transparent" 
                  BorderThickness="0"
                  ItemContainerStyle="{StaticResource HudListViewItemStyle}"
                  Padding="2">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ., Converter={StaticResource UnitObjectDisplayConverter}}" 
                               FontSize="13" 
                               FontFamily="Malgun Gothic"
                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                    <i:Interaction.Behaviors>
                        <local:BindableSelectedItemBehaviorForListView SelectedItem="{Binding SelectedScenarioObject, Mode=TwoWay}" />
                    </i:Interaction.Behaviors>
                </ListView>

            </HeaderedContentControl>

         

            <Grid Grid.Row="1" Margin="0,-25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="추가" 
            Style="{StaticResource HudButtonStyle}" 
            IsEnabled="{Binding IsSimPlayingRev}" 
            Height="30">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="PreviewMouseDown">
                            <i:InvokeCommandAction Command="{Binding AddObjectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>

                <Button Grid.Column="2" Content="수정" 
            Style="{StaticResource HudButtonStyle}" 
            IsEnabled="{Binding EditButtonEnable}" 
            Height="30">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="PreviewMouseDown">
                            <i:InvokeCommandAction Command="{Binding EditObjectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>

                <Button Grid.Column="4" Content="삭제" 
            Style="{StaticResource HudButtonStyle}" 
            IsEnabled="{Binding DeleteButtonEnable}" 
            Height="30">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="PreviewMouseDown">
                            <i:InvokeCommandAction Command="{Binding DeleteObjectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>
            </Grid>
        </Grid>

    
        <Grid Grid.Column="1" Grid.Row="1" Grid.RowSpan="4" Margin="0,385,0,30">
            <HeaderedContentControl Header="상세 정보" Style="{StaticResource HudGroupStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
                    <StackPanel>

                        <StackPanel Visibility="{Binding HelicopterVisible}">

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="ID" 
                            Content="{Binding SelectedScenarioObject.ID}" Foreground="Yellow"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Health">
                                <TextBlock Text="{Binding SelectedScenarioObject.Health}" 
                           Style="{Binding SelectedScenarioObject.Health, Converter={StaticResource HealthToStyleConverter}}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.Status, Converter={StaticResource ObjectHealthStatusToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="지휘기 여부" 
                            Content="{Binding SelectedScenarioObject.IsLeader, Converter={StaticResource IsLeaderToStringConverter}}" Foreground="Yellow"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="위도 (°)" 
                            Content="{Binding SelectedScenarioObject.LOC.Latitude}" ContentStringFormat="N5"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="경도 (°)" 
                            Content="{Binding SelectedScenarioObject.LOC.Longitude}" ContentStringFormat="N5"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="고도 (m)" 
                            Content="{Binding SelectedScenarioObject.LOC.Altitude}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="속도 (m/s)" 
                            Content="{Binding SelectedScenarioObject.velocity.Speed}" ContentStringFormat="N1"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="헤딩 (°)" 
                            Content="{Binding SelectedScenarioObject.velocity.Heading, Converter={StaticResource HeadingConverter}}" ContentStringFormat="N1"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료량 (L)" 
                            Content="{Binding SelectedScenarioObject.Fuel}" ContentStringFormat="N7"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료소모량 (L/Tick)" 
                                Content="{Binding SelectedScenarioObject.FuelConsumption}"
                                ContentStringFormat="F7"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="무장 1 - 미니건" 
                            Content="{Binding SelectedScenarioObject.weapons.Type1}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="무장 2 - 로켓" 
                            Content="{Binding SelectedScenarioObject.weapons.Type2}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="무장 3 - 미사일" 
                            Content="{Binding SelectedScenarioObject.weapons.Type3}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="피격 여부">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.Hit, Converter={StaticResource ObjectAbnormalHitToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Datalink1 상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.Loss1, Converter={StaticResource ObjectAbnormalDataLinkToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Datalink2 상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.Loss2, Converter={StaticResource ObjectAbnormalDataLinkToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Datalink3 상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.Loss3, Converter={StaticResource ObjectAbnormalDataLinkToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료 경고 여부">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.FuelWarning, Converter={StaticResource ObjectAbnormalFuelToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <!--<ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료 위험 여부">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.FuelDanger, Converter={StaticResource ObjectAbnormalFuelDangerToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료 없음 여부">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.FuelZero, Converter={StaticResource ObjectAbnormalFuelZeroToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>-->

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="추락 여부">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.entityAbnormalCause.Crash, Converter={StaticResource ObjectAbnormalCrashToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <!--<ContentControl Style="{StaticResource DataFieldStyle}" Tag="센서장비 상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.PayLoadHealth, Converter={StaticResource ObjectAbnormalSensorStateToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>-->

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="공격 모드" 
                            Content="{Binding SelectedScenarioObject.AttackFlag, Converter={StaticResource AttackFlagToStringConverter}}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Status (개발용)" 
                            Content="{Binding SelectedScenarioObject.LAHStatus, Converter={StaticResource AttackFlagToStringConverter}}"/>
                        </StackPanel>


                        <StackPanel Visibility="{Binding DroneVisible}">

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="ID" 
                            Content="{Binding SelectedScenarioObject.ID}" Foreground="Yellow"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.Status, Converter={StaticResource ObjectHealthStatusToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="위도 (°)" 
                            Content="{Binding SelectedScenarioObject.LOC.Latitude}" ContentStringFormat="N5"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="경도 (°)" 
                            Content="{Binding SelectedScenarioObject.LOC.Longitude}" ContentStringFormat="N5"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="고도 (m)" 
                            Content="{Binding SelectedScenarioObject.LOC.Altitude}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="속도 (m/s)" 
                            Content="{Binding SelectedScenarioObject.velocity.Speed}" ContentStringFormat="N1"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="헤딩 (°)" 
                            Content="{Binding SelectedScenarioObject.velocity.Heading,Converter={StaticResource HeadingConverter}}" ContentStringFormat="N1"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Health" 
                            Content="{Binding SelectedScenarioObject.Health}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료량 (L)" 
                            Content="{Binding SelectedScenarioObject.Fuel}" ContentStringFormat="N7"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="임무장비 상태">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.PayLoadHealth, Converter={StaticResource ObjectHealthStatusToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="연료 경고 여부">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.FuelWarning, Converter={StaticResource ObjectAbnormalFuelToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="탐지 요구 픽셀" 
                            Content="{Binding SelectedScenarioObject.RecogPixel}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="식별 요구 픽셀" 
                            Content="{Binding SelectedScenarioObject.DetectPixel}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="VF Mode (개발용)" 
                            Content="{Binding SelectedScenarioObject.UAVTestMode, Converter={StaticResource VFModeToStringConverter}}"/>
                        </StackPanel>


                        <StackPanel Visibility="{Binding TargetVisible}">

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="ID"
                            Content="{Binding SelectedScenarioObject.ID}" Foreground="Yellow"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="단위 1 ID"
                            Content="{Binding SelectedScenarioObject.Unit1TargetID}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="위도 (°)" 
                            Content="{Binding SelectedScenarioObject.LOC.Latitude}" ContentStringFormat="N5"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="경도 (°)" 
                            Content="{Binding SelectedScenarioObject.LOC.Longitude}" ContentStringFormat="N5"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="고도 (m)" 
                            Content="{Binding SelectedScenarioObject.LOC.Altitude}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="식별">
                                <TextBlock DataContext="{Binding SelectedScenarioObject.Identification, Converter={StaticResource IdentificationStatusToInfoConverter}}"
                           Text="{Binding StatusText}" Foreground="{Binding StatusBrush}"/>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="유형" 
                            Content="{Binding SelectedScenarioObject.Type, Converter={StaticResource ObjectTypeToStringConverter}}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="분류">
                                <TextBlock FontWeight="SemiBold" FontFamily="Consolas" FontSize="13" Foreground="{DynamicResource Hud_Text_Value}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource ObjectPlatformMultiValueConverter}">
                                            <Binding Path="SelectedScenarioObject.PlatformType"/>
                                            <Binding Path="SelectedScenarioObject.Type"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </ContentControl>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="Health" 
                            Content="{Binding SelectedScenarioObject.Health}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="탐지거리 (m)" 
                            Content="{Binding SelectedScenarioObject.DetectRange, StringFormat=N1}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="사정거리 (m)" 
                            Content="{Binding SelectedScenarioObject.AttackRange, StringFormat=N1}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="명중률 (%)" 
                            Content="{Binding SelectedScenarioObject.AttackAccuracy, StringFormat=N1}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="공격 주기 (초)" 
                            Content="{Binding SelectedScenarioObject.AttackDelay, StringFormat=N1}"/>

                            <ContentControl Style="{StaticResource DataFieldStyle}" Tag="피해량" 
                            Content="{Binding SelectedScenarioObject.AttackDamage, StringFormat=N1}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </HeaderedContentControl>
        </Grid>



        <!--임무 계획-->
        <Grid Grid.Column="5" Grid.Row="2" Grid.RowSpan="3">
            <local:UC_Unit_Docking VerticalAlignment="Top"/>
        </Grid>

        <!--지도-->
        <Grid Grid.Column="3" Grid.Row="2" Grid.RowSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>
            <!--<local:View_Map/>-->
            <local:View_Unit_Map Grid.Row="0"/>
            <!--<ProgressBar Grid.Row="1" Value="50"/>-->



            <Grid Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="300" MinHeight="50"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#D9080A10" BorderBrush="{StaticResource SciFi_Border}" BorderThickness="1" CornerRadius="4">
                    <DockPanel LastChildFill="False" Height="35" Width="300">
                        <ToggleButton DockPanel.Dock="Right" 
                          Width="35" Height="30" Margin="2"
                          Style="{StaticResource HudToggleButtonStyle}"
                          IsChecked="{Binding IsLogPanelExpanded, Mode=TwoWay}">
                            <ToggleButton.Content>
                                <TextBlock Text="{Binding IsLogPanelExpanded, Converter={StaticResource BoolToArrowConverter}}" 
                               FontWeight="Bold" FontSize="10"/>
                            </ToggleButton.Content>
                        </ToggleButton>

                        <Button DockPanel.Dock="Right" 
                    Width="30" Height="30" 
                    Content="C" ToolTip="로그 삭제" Margin="0,2"
                    Style="{StaticResource HudButtonStyle}"
                    Command="{Binding ClearLogCommand}"/>

                        <TextBlock Text="EVENT LOG" VerticalAlignment="Center" Margin="10,0" 
                       Foreground="{StaticResource SciFi_Cyan}" FontWeight="Bold" FontFamily="Consolas"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Margin="0,2,0,0"
            Background="#B3000000" 
            BorderBrush="{StaticResource SciFi_Border}" BorderThickness="1" CornerRadius="4"
            Visibility="{Binding IsLogPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
            Width="300">
                    <ListView ItemsSource="{Binding EventLogs}" 
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap" Margin="2" FontFamily="Consolas">
                        <Run Text="{Binding Time}" Foreground="White" FontSize="11"/>
                        <Run Text=" "/>
                        <Run Text="{Binding Message}" Foreground="{Binding Color}" FontWeight="SemiBold" FontSize="12"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <GridSplitter Grid.Row="2"
                  Height="5" 
                  HorizontalAlignment="Stretch" 
                  VerticalAlignment="Center"
                  Background="Transparent"
                  ResizeBehavior="PreviousAndCurrent"
                  ResizeDirection="Rows"
                  Visibility="{Binding IsLogPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="{x:Type GridSplitter}">
                            <Grid Background="Transparent">
                                <Border Background="#40000000" Height="5" VerticalAlignment="Center" CornerRadius="2"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse Width="3" Height="3" Fill="{StaticResource SciFi_Cyan}" Margin="1" Opacity="0.5"/>
                                    <Ellipse Width="3" Height="3" Fill="{StaticResource SciFi_Cyan}" Margin="1" Opacity="0.5"/>
                                    <Ellipse Width="3" Height="3" Fill="{StaticResource SciFi_Cyan}" Margin="1" Opacity="0.5"/>
                                </StackPanel>
                            </Grid>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

            </Grid>

        </Grid>

        <ContentControl Grid.Row="1" Grid.RowSpan="4" Grid.ColumnSpan="6" IsHitTestVisible="True" Visibility="{Binding SceneBorderVisibility}" Style="{StaticResource ScenarioNoticeBorder}">
            <TextBlock Text="편집을 진행하시려면 시나리오 생성/불러오기를 눌러주세요" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource ScenarioNoticeTextBlock}"/>
        </ContentControl>

        <ContentControl Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="6"  IsHitTestVisible="True" Margin="220,0,710,0" Visibility="{Binding SceneBorderVisibility}" Style="{StaticResource ScenarioNoticeBorder}">

            <TextBlock Text="편집을 진행하시려면 시나리오 생성/불러오기를 눌러주세요" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource ScenarioNoticeTextBlock}"/>
        
        </ContentControl>

    </Grid>

</UserControl>

    
    
<Window x:Class="MLAH_Controller.View_SINIL_PopUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Height="600" Width="600" WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  AllowsTransparency="True" WindowStartupLocation="CenterScreen"
        >

    <Window.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="CustomTitleBarTemplate" TargetType="{x:Type Window}">
                <Border CornerRadius="1" BorderBrush="{StaticResource COLOR_GRAY102_Brush}" BorderThickness="2" Background="{StaticResource MLAH_COLOR_BG_Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                         <!--사용자 지정 타이틀 바-->
                        <Border Background="#4d4dff" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                            <TextBlock Text="신일 모의(임시)" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White"/>
                        </Border>

                         <!--콘텐츠 표시 영역--> 
                        <AdornerDecorator Grid.Row="1"  >
                            <ContentPresenter/>
                        </AdornerDecorator>
                    </Grid>
                </Border>
            </ControlTemplate>
            <Style BasedOn="{StaticResource NormalTextBlock}" TargetType="TextBlock"/>
        </ResourceDictionary>
    </Window.Resources>
     <!--리소스 정의 끝--> 

     <!--컨트롤 템플릿 적용--> 
    <Window.Template>
        <StaticResource ResourceKey="CustomTitleBarTemplate"/>
    </Window.Template>

    <Window.DataContext>
        <Binding Source="{x:Static local:ViewModel_SINIL_PopUp.SingletonInstance}"/>
    </Window.DataContext>

    <!--전체 그리드-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>


        <Grid Grid.Column="1" Background="{StaticResource MLAH_COLOR_BG_Brush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Width="130" Content="(협업기저)임무 시작" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Center">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseDown">
                        <i:InvokeCommandAction Command="{Binding MUMTPlayCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>

            

            <!--<TextBlock Grid.Row="0" Text="(협업기저)임무 시작" Foreground="White"/>-->
            <TextBlock Grid.Row="1" Text="Temp" Foreground="White"/>
            
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Width="130" Content="(협업기저)임무 중지" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Center">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseDown">
                        <i:InvokeCommandAction Command="{Binding MUMTStopCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>

            <!--<TextBox Grid.Row="1" Text="{Binding BattlefieldASetTime,StringFormat={}{0:hh\\:mm\\:ss}, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" Width="130"/>-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                
            </Grid>
            <!--<TextBox Text="{Binding SelectedViewModel_ASWHMI_TD_DOGBOX_LIST.lExpireTimeProperty, StringFormat={}{0:hh\\:mm\\:ss}}" Grid.Row="1" Grid.Column="2" TextAlignment="Center"/>-->

        </Grid>

        <!--<Button Grid.Column="1" Grid.Row="1" Width="90" Content="적용" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Center">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding ApplyCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>-->

        <Button Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" Width="60" Content="닫기" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Right">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding CloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
    </Grid>



</Window>



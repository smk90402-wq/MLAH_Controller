<Window x:Class="MLAH_Controller.View_Complexity"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_Controller"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Height="90" Width="400" WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  WindowStartupLocation="Manual" Visibility="Collapsed"
        Top="1300" Left="278"
        >
    <Window.DataContext>
        <Binding Source="{x:Static local:ViewModel_Complexity.SingletonInstance}"/>
    </Window.DataContext>
    
    <!--전체 그리드-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="1" Grid.RowSpan="3" BorderBrush="Gray" BorderThickness="1"/>
        
        <Grid Grid.Row="0" Background="{StaticResource DefaultBg_Brush2}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0.4"/>
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0.4"/>

            <TextBlock Grid.Column="0" Text="복잡협업 복잡도" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding ComplexityNum}" Style="{StaticResource NormalTextBlock}"  HorizontalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>


            <TextBlock Grid.Column="0" Text="( 무인기 수" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="+" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="유인기 수 )" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="x" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="( 협업기저 임무 수" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="+" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="6" Text="개별임무 수 )" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>


            <TextBlock Grid.Column="0" Text="{Binding UAVCounts}" Style="{StaticResource NormalTextBlock}"  HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="+" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="{Binding HelicopterCounts}" Style="{StaticResource NormalTextBlock}"  HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="x" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="{Binding CoBaseMissionCounts}" Style="{StaticResource NormalTextBlock}"  HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="+" Style="{StaticResource NormalTextBlock}" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="6" Text="{Binding IndividualMissionCounts}" Style="{StaticResource NormalTextBlock}"  HorizontalAlignment="Center"/>

        </Grid>
    </Grid>

</Window>



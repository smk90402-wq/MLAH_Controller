<Window x:Class="MLAH_Controller.View_NewSceneAddPopUp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Height="300" Width="360"
      WindowStyle="None" 
      AllowsTransparency="True"
      Background="Transparent"
      IsHitTestVisible="True"
      MouseDown="ViewModel_DialogBase_MouseDown" 
      ResizeMode="NoResize" 
      WindowStartupLocation="CenterScreen" 
      Topmost="True"
      PreviewKeyDown="Window_PreviewKeyDown">

    <Border Background="#E6050A15" 
            BorderBrush="#8000F0FF" 
            BorderThickness="1" 
            CornerRadius="6" 
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2000F0FF" Padding="0,10" CornerRadius="5,5,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Rectangle Width="3" Height="14" Fill="#00F0FF" Margin="0,0,8,0"/>
                    <TextBlock Name="Description" 
                               Text="시나리오 생성" 
                               FontSize="15" 
                               FontWeight="ExtraBold" 
                               Foreground="#00F0FF" 
                               FontFamily="Malgun Gothic"
                               x:FieldModifier="public">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00F0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <Rectangle Width="3" Height="14" Fill="#00F0FF" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Name="Reason" 
                       Grid.Row="1" 
                       Foreground="White" 
                       Margin="20,15,20,5" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       x:FieldModifier="public" />

            <TextBox x:Name="FileNameBox" 
                     Grid.Row="2" 
                     Height="28"
                     Style="{StaticResource NormalTextBox}" 
                     Margin="20,0,20,10" 
                     VerticalContentAlignment="Center"/>

            <TextBlock Name="Reason1" 
                       Grid.Row="3" 
                       Foreground="White" 
                       Margin="20,5,20,5" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       x:FieldModifier="public" />

            <TextBox x:Name="FileDescBox" 
                     Grid.Row="4" 
                     Height="28"
                     Style="{StaticResource NormalTextBox}" 
                     Margin="20,0,20,15"
                     VerticalContentAlignment="Center"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button x:Name="ConfirmButton" 
                        Content="확인" 
                        Width="110" Height="32" 
                        Margin="0,0,15,0" 
                        Click="ConfirmEvent" 
                        Style="{DynamicResource HudButtonStyle}"/>

                <Button x:Name="CancelButton" 
                        Content="취소" 
                        Width="110" Height="32" 
                        Click="CancelEvent" 
                        Style="{DynamicResource HudButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
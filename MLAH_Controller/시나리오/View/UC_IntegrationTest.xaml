<UserControl x:Class="MLAH_Controller.UC_IntegrationTest"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MLAH_Controller"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="400"
             Background="{StaticResource MLAH_COLOR_BG_Brush}">
    <UserControl.DataContext>
        <Binding Source="{x:Static local:ViewModel_IntegrationTest.SingletonInstance}"/>
    </UserControl.DataContext>
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="통합 운용 시나리오 테스트" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

            <Button Content="1. 재계획 생성 및 캐시 저장" 
                    Command="{Binding GenerateReplansCommand}" 
                    Style="{StaticResource NormalButtonStyle}" Margin="0,5"/>

            <Separator Margin="0,10" Background="Gray"/>

            <TextBlock Text="[Case A] 시스템 자동 인가" FontWeight="Bold" Foreground="#FF5722" Margin="0,5"/>
            <Button Content="2-A. 시스템 인가 메시지 수신 (53114)" 
                    Command="{Binding SendImplicitUpdateCommand}"
                    Background="#FF5722" BorderBrush="#FF5722"
                    Style="{StaticResource NormalButtonStyle}" Margin="0,5"/>

            <Separator Margin="0,10" Background="Gray"/>

            <TextBlock Text="[Case B] 수동 인가 절차" FontWeight="Bold" Foreground="#2196F3" Margin="0,5"/>
            <Button Content="2-B(1). 옵션 정보 메시지 수신 (53113)" 
                    Command="{Binding SendOptionsCommand}"
                    Style="{StaticResource NormalButtonStyle}" Margin="0,5"/>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="2-B(2). 파일럿 결정:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="옵션 #1" Command="{Binding SendPilotDecisionCommand}" CommandParameter="1" Style="{StaticResource NormalButtonStyle}" Width="60" Margin="0,0,5,0"/>
                <Button Content="옵션 #2" Command="{Binding SendPilotDecisionCommand}" CommandParameter="2" Style="{StaticResource NormalButtonStyle}" Width="60" Margin="0,0,5,0"/>
                <Button Content="옵션 #3" Command="{Binding SendPilotDecisionCommand}" CommandParameter="3" Style="{StaticResource NormalButtonStyle}" Width="60"/>
            </StackPanel>

            <Separator Margin="0,10" Background="Gray"/>

            <TextBlock Text="[공통] 임무 수행 확인" FontWeight="Bold" Foreground="#4CAF50" Margin="0,5"/>
            <Button Content="3. 임무 완료 신호 수신 시뮬레이션 (LAH#1)" 
                    Command="{Binding SendMissionDoneCommand}"
                    Background="#4CAF50" BorderBrush="#4CAF50"
                    Style="{StaticResource NormalButtonStyle}" Margin="0,5"/>

            <GroupBox Header="로그" Foreground="White" Margin="0,10,0,0">
                <TextBox Text="{Binding LogText}" Height="100" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Background="#2D2D30" Foreground="White"/>
            </GroupBox>

        </StackPanel>
    </Grid>
</UserControl>
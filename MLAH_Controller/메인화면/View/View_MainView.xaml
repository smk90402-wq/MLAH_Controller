        <Border Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Margin="10,5" CornerRadius="10" BorderThickness="1" Background="{StaticResource SciFi_DarkBg}" BorderBrush="{StaticResource SciFi_Border}">

                <Border Grid.Row="0" BorderBrush="{StaticResource SciFi_Border}" BorderThickness="0,0,0,1" Margin="10,0" Background="{StaticResource SciFi_DarkBg}" CornerRadius="10,10,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Style="{StaticResource LedStatusStyle}" Margin="5,0,10,0">
                            <Ellipse.Tag>
                                <MultiBinding Converter="{StaticResource StatusToCombinedStatusConverter}">
                                    <Binding Path="CTRLHwStatus"/>
                                    <Binding Path="CTRLSwStatus"/>
                                </MultiBinding>
                            </Ellipse.Tag>
                        </Ellipse>
                        <TextBlock Text=" 시험운용통제" Style="{StaticResource SciFiHeaderStyle}"/>
                    </StackPanel>
                </Border>
                <Grid Grid.Row="1" Margin="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PWR STATUS" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatusValueBoxStyle}">
                        <TextBlock Style="{StaticResource StatusTextStyle}">
                            <TextBlock.DataContext>
                                <Binding Path="CTRLHwStatus" Converter="{StaticResource HwStatusToInfoConverter}"/>
                            </TextBlock.DataContext>
                            <TextBlock.Text>
                                <Binding Path="StatusText"/>
                            </TextBlock.Text>
                            <TextBlock.Foreground>
                                <Binding Path="StatusBrush"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="S/W STATUS" Style="{StaticResource StatusLabelStyle}"/>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatusValueBoxStyle}">
                        <TextBlock Style="{StaticResource StatusTextStyle}">
                            <TextBlock.DataContext>
                                <Binding Path="CTRLSwStatus" Converter="{StaticResource SwStatusToInfoConverter}"/>
                            </TextBlock.DataContext>
                            <TextBlock.Text>
                                <Binding Path="StatusText"/>
                            </TextBlock.Text>
                            <TextBlock.Foreground>
                                <Binding Path="StatusBrush"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Border>
                </Grid>
            </Grid>
        </Border>


        <Style x:Key="LedStatusStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="StrokeThickness" Value="1"/>

            <Setter Property="Fill" Value="#222222"/>
            <Setter Property="Stroke" Value="#555555"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Transparent" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Green">
                    <Setter Property="Stroke" Value="{StaticResource Holo_Green_Brush}"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="GreenStoryboard" Storyboard="{StaticResource BlinkGreen}"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="GreenStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Red">
                    <Setter Property="Stroke" Value="{StaticResource Holo_Red_Brush}"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="RedStoryboard" Storyboard="{StaticResource BlinkRed}"/>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="RedStoryboard"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Text_Normal}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="StatusValueBoxStyle" TargetType="Border">
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>


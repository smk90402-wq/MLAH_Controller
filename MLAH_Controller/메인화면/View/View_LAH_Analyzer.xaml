                                <Ellipse Canvas.Left="1025" Canvas.Top="425" Height="10" Width="10" Fill="Blue"/>
                                <Ellipse Canvas.Left="905" Canvas.Top="945" Height="10" Width="10" Fill="Blue"/>
                                <Ellipse Canvas.Left="345" Canvas.Top="945" Height="10" Width="10" Fill="Blue"/>
                                <Ellipse Canvas.Left="225" Canvas.Top="425" Height="10" Width="10" Fill="Blue"/>


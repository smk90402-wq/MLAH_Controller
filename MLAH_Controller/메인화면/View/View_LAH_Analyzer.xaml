                            <TextBlock Grid.Column="1" Grid.Row="4" Text="End : " Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="White"/>
                            <TextBlock Grid.Column="2" Grid.Row="4" Text="2024-04-01 12:03:12" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top"/>

                            <TextBlock Grid.Column="1" Grid.Row="6" Text="[1] Coverage" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="White"/>
                            <TextBlock Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="7" Text="목표지역 정찰을 누락된 부분이 없도록 임무를 계획하였는가?...." Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="White" />

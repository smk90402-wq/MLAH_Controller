    <!--<WindowChrome>
        <WindowChrome CaptionHeight="50"/>
    </WindowChrome>-->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="1240"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <DataGrid x:Name="testgrid" Grid.Column="0" Grid.Row="0" Style="{StaticResource NormalDataGrid}" HorizontalScrollBarVisibility="Disabled">

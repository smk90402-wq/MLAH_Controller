                        <TextBlock Grid.Column="1" Text="8" Margin="140,120,0,0" Style="{StaticResource NormalTextBlock}"/>

                        <Grid Grid.Column="1" Grid.RowSpan="10">
                            <Canvas>
                                <!-- 배경 격자 -->
                                <Polygon Points="640,200 1080,400 960,1000 320,1000 200,400"
                     Stroke="Gray" StrokeThickness="2" Fill="#00000000"
                     Opacity="0.3"/>

                                <!-- 주요 결과 표현 -->
                                <Polygon Points="640,230 1030,430 910,950 350,950 230,430"
                     Stroke="Blue" StrokeThickness="3" Fill="#00000000"

                                <TextBlock Text="Task Balancing" FontSize="24" FontWeight="Bold" Canvas.Left="150" Canvas.Top="990"/>
                                <TextBlock Text="Concealment" FontSize="24" FontWeight="Bold" Canvas.Left="80" Canvas.Top="300"/>
                            </Canvas>


                    <DataGridTextColumn Header="파일명" Width="210" IsReadOnly="True" Binding="{Binding Column1}"/>
                    <DataGridTextColumn Header="날짜" Width="210" IsReadOnly="True" Binding="{Binding Column2}"/>
                    <DataGridTextColumn Header="데이터 종류" Width="210" IsReadOnly="True" Binding="{Binding Column3}"/>

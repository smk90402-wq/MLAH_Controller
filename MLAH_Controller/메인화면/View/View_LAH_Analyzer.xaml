                     Stroke="Green" StrokeThickness="2" Fill="#00000000"
                     Opacity="0.3"/>
                                <Polygon Points="640,290 930,490 810,850 410,850 290,490"
                     Stroke="Yellow" StrokeThickness="2" Fill="#00000000"
                     Opacity="0.3"/>


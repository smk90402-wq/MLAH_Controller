            <TextBlock Grid.Column="0" Grid.Row="4" Text="분석 데이터 종류 : " Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="White"/>

            <TextBlock Grid.Column="1" Grid.Row="2" Text="AnalysisData2.dat" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1" Grid.Row="3" Text="2025-08-09 11:12:43" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1" Grid.Row="4" Text="분석 데이터 모델" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="Red"/>

        </Grid>





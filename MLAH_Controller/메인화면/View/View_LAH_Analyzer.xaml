                                <Polygon Points="320,100 533,200 480,400 160,400 107,200"
                     Stroke="Black" StrokeThickness="1" Fill="#FFA3E4D7"/>
                                <Polyline Points="160,180 213,160 320,200 427,160 480,180 427,220 320,250 213,220 160,250" Stroke="Blue" StrokeThickness="2"/>
                                <Polyline Points="160,230 213,210 320,250 427,210 480,230 427,270 320,300 213,270 160,300" Stroke="Green" StrokeThickness="2"/>

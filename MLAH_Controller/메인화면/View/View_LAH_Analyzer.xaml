            <Button Grid.Column="2" Grid.Row="0" Content="분석 결과 파일 전시" Height="30" Width="140" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0"/>

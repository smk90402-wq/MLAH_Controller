                            <TextBlock Grid.Column="1" Grid.Row="18" Text="[5] Concealmment" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="White"/>
                            <TextBlock Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="19" Text="유인기 추천위치는 표적으로부터 탐지되지 않도록 임무를 계획하였는가?...." Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Foreground="White" />
                            <TextBlock Grid.Column="3" Grid.ColumnSpan="3" Grid.Row="19" Text="83 %" Style="{StaticResource NormalTextBlock}" VerticalAlignment="Top" Margin="150,0,0,0" />


                     Fill="red" Opacity="0.5"/>
                                <TextBlock Text="촬영 커버리지: 87.4%" FontSize="16" FontWeight="Bold" Canvas.Left="400" Canvas.Top="660" Foreground="Black"/>
                            </Canvas>


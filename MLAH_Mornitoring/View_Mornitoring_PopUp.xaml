<Window x:Class="MLAH_Mornitoring.View_Mornitoring_PopUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:local="clr-namespace:MLAH_Mornitoring"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Height="1000" Width="1305" WindowStyle="None" ResizeMode="NoResize" Topmost="False"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  AllowsTransparency="True" WindowStartupLocation="CenterScreen"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        Loaded="View_Mornitoring_PopUp_Loaded"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        d:DataContext="{d:DesignInstance Type=local:ViewModel_Mornitoring_PopUp, IsDesignTimeCreatable=True}">

    <Window.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="CustomTitleBarTemplate" TargetType="{x:Type Window}">
                <Border CornerRadius="1" BorderBrush="{StaticResource COLOR_GRAY102_Brush}" BorderThickness="2" Background="{StaticResource MLAH_COLOR_BG_Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                         <!--사용자 지정 타이틀 바-->
                        <Border Background="#4d4dff" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                            <TextBlock Text="실시간 모니터링" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="White"/>
                        </Border>

                         <!--콘텐츠 표시 영역--> 
                        <AdornerDecorator Grid.Row="1"  >
                            <ContentPresenter/>
                        </AdornerDecorator>
                    </Grid>
                </Border>
            </ControlTemplate>
            <Style BasedOn="{StaticResource NormalTextBlock}" TargetType="TextBlock"/>
            
            <!-- TreeView 스타일 -->
            <Style x:Key="TreeViewStyle" TargetType="TreeView">
                <Setter Property="Background" Value="{StaticResource MLAH_COLOR_BG_Brush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            
            <!-- TreeViewItem 스타일 -->
            <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="2"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
     <!--리소스 정의 끝--> 

     <!--컨트롤 템플릿 적용--> 
    <Window.Template>
        <StaticResource ResourceKey="CustomTitleBarTemplate"/>
    </Window.Template>

    <!--<Window.DataContext>
        <Binding Source="{x:Static local:ViewModel_Mornitoring_PopUp.SingletonInstance}"/>
    </Window.DataContext>-->

    <!--전체 그리드-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="510"/>
            <ColumnDefinition Width="490"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <ListView Grid.Column="0" Grid.Row="0" 
          Background="{StaticResource MLAH_COLOR_BG_Brush}" 
          ItemsSource="{Binding MessageItems}" 
          Foreground="White"
          dx:ThemeManager.ThemeName="VS2019Dark">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <dxe:CheckEdit IsChecked="{Binding IsChecked}" 
                               Margin="5" 
                               Padding="0"/>

                        <TextBlock Text="{Binding Name}" 
                           VerticalAlignment="Center" 
                           Foreground="White" 
                           Margin="5,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>



        <CheckBox Grid.Row="1" Grid.Column="1"
              Content="Open Tree" 
              IsChecked="{Binding IsOpenTreeChecked}" 
              Style="{StaticResource NormalCheckBoxStyle}" 
              Foreground="White"
              VerticalAlignment="Center" 
              Margin="5,0,0,0"/>

        <dxg:GridControl Grid.Column="1" Grid.Row="0" x:Name="MessageGridControl"
                     dx:ThemeManager.ThemeName="VS2019Dark"
                     ItemsSource="{Binding FilteredDataSource}"
                     SelectedItem="{Binding SelectedMornitoringData}">
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="IP" Header="IP" Width="100" AllowEditing="False"/>
                <dxg:GridColumn FieldName="Protocol" Header="Protocol" Width="100" AllowEditing="False"/>
                <dxg:GridColumn FieldName="MessageName" Header="Message" Width="200" AllowEditing="False"/>
                <dxg:GridColumn FieldName="ReceivedTime" Header="Time" Width="100" AllowEditing="False"/>
            </dxg:GridControl.Columns>
            <dxg:GridControl.View>
                <dxg:TableView 
                    x:Name="MessageTableView"
                    AllowPerPixelScrolling="True" 
                           ShowGroupPanel="False" 
                           ShowIndicator="False" 
                           NavigationStyle="Row"
                           HorizontalScrollbarVisibility="Hidden"
                           KeepViewportOnDataUpdate="True"
                           AllowEditing="False"/>
            </dxg:GridControl.View>
        </dxg:GridControl>
        <!--<dxg:GridControl Grid.Column="2" Grid.Row="0" dx:ThemeManager.ThemeName="VS2019Dark"
                     ItemsSource="{Binding SelectedMornitoringData.FieldNodes}">
        </dxg:GridControl>-->

       
        <dxg:GridControl Grid.Column="2" Grid.Row="0" dx:ThemeManager.ThemeName="VS2019Dark" 
                 ItemsSource="{Binding DetailNodes}">
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Name" Header="Field" Width="150" AllowEditing="False"/>
                <dxg:GridColumn FieldName="Value" Header="Value" Width="*" AllowEditing="False"/>
            </dxg:GridControl.Columns>
            <dxg:GridControl.View >
                <dxg:TreeListView x:Name="treeListView" 
                          TreeDerivationMode="ChildNodesSelector"
                          ChildNodesSelector="{StaticResource MessageNodeChildNodesSelector}"
                          AllowPerPixelScrolling="True" 
                          ShowHorizontalLines="True"
                            AllowSorting="False"
                          ShowVerticalLines="True"
                          ShowIndicator="False">
                    <dxg:TreeListView.RowStyle>
                        <Style TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.IsHighlighted}" Value="True">
                                    <Setter Property="Background" Value="#2A5298" />
                                    <Setter Property="Foreground" Value="#FFD700" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:TreeListView.RowStyle>
                </dxg:TreeListView>
            </dxg:GridControl.View>
        </dxg:GridControl>




        <TextBox Grid.Row="1" Grid.Column="1" Height="20" Width="50" Text="{Binding FilterId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NormalTextBox}" HorizontalAlignment="Right" Margin="0,0,0,0" IsEnabled="{Binding IsFilteringEnabled, Converter={StaticResource InvertBooleanConverter}, FallbackValue=False}" TextAlignment="Center"/>
        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,2,50,0" HorizontalAlignment="Right" Width="20" IsChecked="{Binding IsFilteringEnabled}"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Text="ObjectNumber Filter : " HorizontalAlignment="Right" Margin="0,0,80,0"/>


        <Button Grid.Column="2" Grid.Row="3" Width="60" Content="닫기" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Right">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewMouseDown">
                    <i:InvokeCommandAction Command="{Binding CloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=Window}}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Button>
    </Grid>



</Window>



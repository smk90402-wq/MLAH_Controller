    <Style x:Key="NormalButtonStyle" TargetType="{x:Type Button}">
        <!--<Setter Property="Width" Value="25"/>
        <Setter Property="Height" Value="25"/>-->
        <Setter Property="Background" Value="#3f4654" />
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_WHITE_Brush}"/>
        <Setter Property="FontFamily" Value="Malgun Gothic" />
        <Setter Property="FontSize" Value="10pt" />
        <Setter Property="FontStyle" Value="Normal" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                        <Border x:Name="bdButton" CornerRadius="1.5" BorderThickness="1" BorderBrush="{TemplateBinding Background}" TextBlock.TextAlignment="Center" Background="{TemplateBinding Background}" >
                            <Grid>
                                <Border x:Name="bdInnerShadowU" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource InnerShadowN1_10p}" />
                                <Border x:Name="bdInnerShadowD" BorderThickness="0,0,0,1" BorderBrush="#2f343e" />
                                <ContentPresenter x:Name="tcp" Content="{TemplateBinding Content}" VerticalAlignment="Center" Margin="0,0,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="True">
                            <Setter TargetName="tcp" Property="TextElement.FontFamily" Value="{Binding Path=(TextElement.FontFamily), RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="tcp" Property="TextElement.FontSize" Value="{Binding Path=(TextElement.FontSize), RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="tcp" Property="TextElement.Foreground" Value="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource nc_on_color}" />
                            <Setter TargetName="bdButton" Property="BorderBrush" Value="{DynamicResource yellow_color}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{DynamicResource nc_on_color}" />
                            <Setter TargetName="bdButton" Property="BorderBrush" Value="{x:Null}" />
                            <Setter TargetName="bdInnerShadowU" Property="BorderBrush"  Value="{DynamicResource black_color}" />
                            <Setter TargetName="bdInnerShadowD" Property="BorderBrush" Value="{DynamicResource InnerShadowN1}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NormalTextBlock" TargetType="{x:Type TextBlock}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}"/>
        <Setter Property="Margin" Value="{DynamicResource UIELEMENT_MARGIN}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontStyle" Value="Normal" />
        <Setter Property="Margin" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NormalComboBox" TargetType="{x:Type ComboBox}">
        <Setter Property="FontFamily" Value="Malgun Gothic" />
        <Setter Property="FontSize" Value="10pt" />
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}"/>
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="10"/>
        <Setter Property="MaxHeight" Value="50"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="MinWidth" Value="30"/>
        <Setter Property="MaxWidth" Value="600"/>
        <Setter Property="Width" Value="100"/>
        <Setter Property="FontStyle" Value="Normal" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Style="{DynamicResource subDropDownToggleButtonStyle}" Name="ToggleButton" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                        <Viewbox StretchDirection="DownOnly">
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" TextElement.FontFamily="Malgun Gothic" TextElement.FontSize="10pt" TextBlock.Foreground="{DynamicResource MLAH_COLOR_Value_Brush}" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="1,0,20,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Viewbox>
                        <Polyline x:Name="UnderArrow" Points="0,0 10,0, 5,6" Width="10" Height="6" Fill="{DynamicResource MLAH_COLOR_SELECTABLE_TEXT_Brush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,-2,5,0"/>
                        <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}">
                                <Border x:Name="DropDownBorder" Background="{DynamicResource gray_color}" BorderThickness="0"/>
                                <ScrollViewer Margin="0" Focusable="False" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" HorizontalAlignment="Stretch" TextElement.FontFamily="Malgun Gothic" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter TargetName="UnderArrow" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="ToggleButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="ContentSite" Property="Margin" Value="0"/>
                        </Trigger>
                        <Trigger Property="IsGrouping" Value="true">
                            <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                        </Trigger>
                        <Trigger Property="IsEditable" Value="true">
                            <Setter Property="IsTabStop" Value="false"/>
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="true">
                            <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="subDropDownToggleButtonStyle"  TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_Value_Brush}"/>
        <Setter Property="Background" Value="{DynamicResource nc_off_color}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="bdButton" CornerRadius="2" Background="{TemplateBinding Background}" >
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderThickness" Value="1" TargetName="bdButton" />
                            <Setter Property="BorderBrush" Value="{DynamicResource yellow_color}" TargetName="bdButton" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--위치 선택 토글 버튼 스타일-->
    <Style x:Key="POSSelectToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Width" Value="25"/>
        <Setter Property="Height" Value="25"/>
        <Setter Property="Background" Value="#3f4654" />
        <Setter Property="FontFamily" Value="Malgun Gothic" />
        <Setter Property="FontSize" Value="10pt" />
        <Setter Property="Foreground" Value="{DynamicResource MLAH_COLOR_WHITE_Brush}"/>
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Grid>
                        <Border x:Name="bdButton" CornerRadius="1.5" BorderThickness="1" BorderBrush="{TemplateBinding Background}" TextBlock.TextAlignment="Center" Background="{TemplateBinding Background}" >
                            <Grid>
                                <Border x:Name="bdInnerShadowU" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource InnerShadowN1}" />
                                <Border x:Name="bdInnerShadowD" BorderThickness="0,0,0,1" BorderBrush="#2f343e" />

                                <Grid x:Name="tcp" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                        <!--<Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="Background" Value="{DynamicResource CTSL_OVER}" />
                        </Trigger>-->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="{DynamicResource POS_Click}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter Property="Background" Value="{DynamicResource POS_Normal}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--borderless 수직 stretch 스크롤뷰어 스타일-->
    <Style TargetType="{x:Type ScrollViewer}" x:Key="SVStyle_TextBox">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Viewbox.Stretch" Value="Uniform" />
        <Setter Property="Viewbox.StretchDirection" Value="DownOnly" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border x:Name="noViewbox" Grid.Column="0" BorderThickness="0" BorderBrush="{DynamicResource nc_on_color}" Visibility="Collapsed" Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=TextBox}}" Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=TextBox}}">
                            <ScrollContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" CanContentScroll="True"/>
                        </Border>
                        <Border x:Name="yesViewbox" Grid.Column="0" BorderThickness="0" BorderBrush="{DynamicResource nc_on_color}" Visibility="Visible" Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=TextBox}}" Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=TextBox}}">
                            <Viewbox Stretch="{TemplateBinding Viewbox.Stretch}" StretchDirection="{TemplateBinding Viewbox.StretchDirection}" >
                                <ScrollContentPresenter  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Viewbox>
                        </Border>
                        <ScrollBar x:Name="PART_VerticalScrollBar" 
                             Value="{TemplateBinding VerticalOffset}"
                             Maximum="{TemplateBinding ScrollableHeight}"
                             ViewportSize="{TemplateBinding ViewportHeight}"  
                             Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Grid.Column="1"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                             Orientation="Horizontal"
                             Grid.Row="1"
                             Grid.Column="0"
                             Value="{TemplateBinding HorizontalOffset}"
                             Maximum="{TemplateBinding ScrollableWidth}"
                             ViewportSize="{TemplateBinding ViewportWidth}"
                             Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto">
                            <Setter TargetName="noViewbox" Property="Visibility" Value="Visible" />
                            <Setter TargetName="yesViewbox" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="yesViewbox" Property="Background" Value="{DynamicResource MLAH_COLOR_POPUP_DLG_BG_Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


<UserControl x:Class="MLAH_LogAnalyzer.View_ScoreMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:local="clr-namespace:MLAH_LogAnalyzer"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core" 
        xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts" 
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors" 
        xmlns:dxcr="http://schemas.devexpress.com/winfx/2008/xaml/charts/rangecontrolclient"
        xmlns:dxgn="http://schemas.devexpress.com/winfx/2008/xaml/gantt" 
        xmlns:dxm="http://schemas.devexpress.com/winfx/2008/xaml/map"
             d:DataContext="{d:DesignInstance Type=local:View_ScoreMain, IsDesignTimeCreatable=True}"
             >

    <UserControl.Resources>
        <ResourceDictionary>
            
            <Style BasedOn="{StaticResource NormalTextBlock}" TargetType="TextBlock"/>
            
            <!-- TreeView 스타일 -->
            <Style x:Key="TreeViewStyle" TargetType="TreeView">
                <Setter Property="Background" Value="{StaticResource MLAH_COLOR_BG_Brush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            
            <!-- TreeViewItem 스타일 -->
            <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="2"/>
            </Style>

            <dxc:CustomMarker2DModel x:Key="yellowCircleMarker">
                <dxc:CustomMarker2DModel.PointTemplate>
                    <ControlTemplate>
                        <Rectangle Width="10" Height="10" 
                     Fill="Yellow" 
                     Stroke="DarkGoldenrod" 
                     StrokeThickness="1"/>
                    </ControlTemplate>
                </dxc:CustomMarker2DModel.PointTemplate>
            </dxc:CustomMarker2DModel>

          
        </ResourceDictionary>
    </UserControl.Resources>
     <!--리소스 정의 끝--> 


    <!--전체 그리드-->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--불러오기-->
        <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" >
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="700"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox BorderBrush="White" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Column="0" Width="150" Height="25" Content="Log 불러오기" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" Margin="0,0,10,0" PreviewMouseDown="Button_PreviewMouseDown"/>

                    <TextBlock Grid.Row="1" Text="시나리오 이름 : " Foreground="White"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding SelectedScenarioName}" />


                    <TextBlock Grid.Row="2" Text="시나리오 시작 시간 : " Foreground="White"/>
                    <TextBlock Grid.Column="1" Grid.Row="2">
                        <TextBlock.Text>
                            <Binding Path="LogStartTime" Converter="{StaticResource UlongToDateTimeConverter}" StringFormat="yyyy-MM-dd HH:mm:ss"/>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>

            </GroupBox>

            <ListView x:Name="ScenarioListView" Grid.Row="1" Height="700" Background="{StaticResource MLAH_COLOR_BG_Brush}" ItemsSource="{Binding AllScenarioItems}" Foreground="White" VerticalAlignment="Top" BorderBrush="White">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsChecked}" 
                          IsEnabled="{Binding IsCheckboxEnabled}" 
                          VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding ScenarioName}" 
                           Foreground="{Binding StatusColor}" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Grid.Column="0" Grid.Row="2" Width="150" Height="25" Content="분석 시작" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" PreviewMouseDown="Button_Analyze_Click" Margin="10,0,0,0"/>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                
                <Button Grid.Column="0" Width="150" Height="25" Content="시나리오 전체 선택" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" PreviewMouseDown="Button_PreviewMouseDown_1" Margin="10,0,0,0"/>
                <Button Grid.Column="1" Width="150" Height="25" Content="시나리오 전체 해제" Style="{StaticResource NormalButtonStyle}" HorizontalAlignment="Left" PreviewMouseDown="Button_PreviewMouseDown_2"/>
            </Grid>

            <TextBlock Grid.Row="4" Style="{StaticResource NormalTextBlock}" Text="Input TimeStamp : " VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White"/>
            <TextBox Grid.Row="4" Style="{StaticResource NormalTextBox}"  Text="{Binding lnputConvertedTime,UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" Margin="130,0,0,0" HorizontalAlignment="Left"/>
            <Button Grid.Row="4" Style="{StaticResource NormalButtonStyle}" Content="변환" Width="50" Height="25" VerticalAlignment="Center" Margin="260,0,0,0" PreviewMouseDown="Button_PreviewMouseDown_3"/>

            <TextBlock Grid.Row="5" Margin="130,0,0,0">
                <TextBlock.Text>
                    <Binding Path="ConvertedTime" Converter="{StaticResource UlongToDateTimeConverter}" StringFormat="yyyy-MM-dd HH:mm:ss.fff" />
                </TextBlock.Text>
            </TextBlock>

        </Grid>
        <Grid Grid.Column="1" Grid.RowSpan="3">
            <local:UC_Unit_Docking 
        SelectedScenario="{Binding SelectedScenarioSummary, Mode=TwoWay}" />
        </Grid>

        
    </Grid>


    




</UserControl>



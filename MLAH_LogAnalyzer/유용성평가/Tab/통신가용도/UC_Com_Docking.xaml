<UserControl x:Class="MLAH_LogAnalyzer.UC_Com_Docking"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_LogAnalyzer"
        mc:Ignorable="d" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts" 
        xmlns:dxdove="http://schemas.devexpress.com/winfx/2008/xaml/docking/visualelements"
        dx:ThemeManager.Theme="VS2019Dark"
        Background="{StaticResource MLAH_COLOR_BG_Brush}"  
        d:DataContext="{d:DesignInstance Type=local:UC_Com_Docking, IsDesignTimeCreatable=True}"
        >
    
    
    <Grid>
        <DockPanel>
            <dxdo:DockLayoutManager x:Name="DemoDockContainer" FloatingMode="Desktop"  Background="{StaticResource MLAH_COLOR_BG_Brush}">

                <dxdo:LayoutGroup ShowCloseButton="False" >
                    <!--<dxdo:LayoutGroup.Resources>
                        <Style TargetType="dxdo:LayoutPanel">
                            <Setter Property="Appearance">
                                <Setter.Value>
                                    <dxdo:Appearance>
                                        <dxdo:Appearance.Normal>
                                            <dxdo:AppearanceObject Foreground="White" />
                                        </dxdo:Appearance.Normal>
                                        <dxdo:Appearance.Active>
                                            <dxdo:AppearanceObject Foreground="Black" FontWeight="Bold" />
                                        </dxdo:Appearance.Active>
                                    </dxdo:Appearance>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="dxdo:DocumentPanel" BasedOn="{StaticResource {x:Type dxdo:LayoutPanel}}"/>


                    </dxdo:LayoutGroup.Resources>-->
                
                <dxdo:DocumentGroup >
                        <dxdo:DocumentPanel Caption="UAV 1" 
                        Background="{StaticResource MLAH_COLOR_BG_Brush}" 
                        IsActive="True" 
                        AllowClose="False">
                            <Grid>
                                <dxc:ChartControl Name="ScoreChart1" CrosshairEnabled="True" CustomDrawCrosshair="ScoreChart_CustomDrawCrosshair"
                                                  MouseLeftButtonDown="Chart_MouseLeftButtonDown1">
    <dxc:ChartControl.Diagram>
        <dxc:XYDiagram2D SeriesDataMember="AircraftID" EnableAxisXNavigation="True" EnableAxisYNavigation="False">
            <dxc:XYDiagram2D.AxisY>
                <dxc:AxisY2D>
                    <dxc:AxisY2D.Title>
                        <dxc:AxisTitle
                    Content="Connection" />
                    </dxc:AxisY2D.Title>

                                                    <dxc:AxisY2D.WholeRange>
                                                        <dxc:Range/>
                                                    </dxc:AxisY2D.WholeRange>

                                                    <dxc:AxisY2D.VisualRange>
                                                        <dxc:Range/>
                                                    </dxc:AxisY2D.VisualRange>

                                      
                                                </dxc:AxisY2D>
            </dxc:XYDiagram2D.AxisY>

            <dxc:XYDiagram2D.AxisX>
                <dxc:AxisX2D x:Name="axisX" Visible="True" Alignment="Near" >
                    <dxc:AxisX2D.DateTimeScaleOptions>
                        <dxc:ContinuousDateTimeScaleOptions/>
                    </dxc:AxisX2D.DateTimeScaleOptions>
                    <dxc:AxisX2D.Label>
                        <dxc:AxisLabel TextPattern="{}{V:mm:ss.fff}"/>
                    </dxc:AxisX2D.Label>

                </dxc:AxisX2D>
            </dxc:XYDiagram2D.AxisX>

            <dxc:XYDiagram2D.SeriesTemplate>
                <dxc:LineSeries2D
                ArgumentDataMember="Timestamp"
                ArgumentScaleType="DateTime" 
                MarkerSize="10" 
                ValueDataMember="Status" ValueScaleType="Numerical" 
                CrosshairLabelPattern="UAV {S}: {V}" />
            </dxc:XYDiagram2D.SeriesTemplate>
        </dxc:XYDiagram2D>
    </dxc:ChartControl.Diagram>
    <dxc:ChartControl.Legend>
        <dxc:Legend
    HorizontalPosition="Right"
    ReverseItems="True" />
    </dxc:ChartControl.Legend>
      
    <!--<dxc:ChartControl.Titles>
        <dxc:Title
    Dock="Top"
    HorizontalAlignment="Center">통신 가용도 - UAV 1</dxc:Title>
    </dxc:ChartControl.Titles>-->
 
    <dxc:ChartControl.CrosshairOptions>
        <dxc:CrosshairOptions GroupHeaderPattern="Time : {A:yyyy-MM-dd HH:mm:ss.fff}"/>
    </dxc:ChartControl.CrosshairOptions>
</dxc:ChartControl>
                            </Grid>
                            
                        </dxdo:DocumentPanel>

                        <dxdo:DocumentPanel Caption="UAV 2" Background="{StaticResource MLAH_COLOR_BG_Brush}" AllowClose="False">
                            <Grid>
                                <dxc:ChartControl Name="ScoreChart2" CrosshairEnabled="True" CustomDrawCrosshair="ScoreChart_CustomDrawCrosshair"
                                                  MouseLeftButtonDown="Chart_MouseLeftButtonDown2">
                                    <dxc:ChartControl.Diagram>
                                        <dxc:XYDiagram2D SeriesDataMember="AircraftID" EnableAxisXNavigation="True" EnableAxisYNavigation="False">
                                            <dxc:XYDiagram2D.AxisY>
                                                <dxc:AxisY2D>
                                                    <dxc:AxisY2D.Title>
                                                        <dxc:AxisTitle
                    Content="Connection" />
                                                    </dxc:AxisY2D.Title>

                                                    <dxc:AxisY2D.WholeRange>
                                                        <dxc:Range/>
                                                    </dxc:AxisY2D.WholeRange>

                                                    <dxc:AxisY2D.VisualRange>
                                                        <dxc:Range/>
                                                    </dxc:AxisY2D.VisualRange>
                                                </dxc:AxisY2D>
                                            </dxc:XYDiagram2D.AxisY>

                                            <dxc:XYDiagram2D.AxisX>
                                                <dxc:AxisX2D Visible="True" Alignment="Near" >
                                                    <dxc:AxisX2D.DateTimeScaleOptions>
                                                        <dxc:ContinuousDateTimeScaleOptions/>
                                                    </dxc:AxisX2D.DateTimeScaleOptions>
                                                    <dxc:AxisX2D.Label>
                                                        <dxc:AxisLabel TextPattern="{}{V:mm:ss.fff}"/>
                                                    </dxc:AxisX2D.Label>

                                                </dxc:AxisX2D>
                                            </dxc:XYDiagram2D.AxisX>

                                            <dxc:XYDiagram2D.SeriesTemplate>
                                                <dxc:LineSeries2D
                ArgumentDataMember="Timestamp"
                ArgumentScaleType="DateTime" 
                MarkerSize="10" 
                ValueDataMember="Status" ValueScaleType="Numerical" 
                CrosshairLabelPattern="UAV {S}: {V}" />
                                            </dxc:XYDiagram2D.SeriesTemplate>
                                        </dxc:XYDiagram2D>
                                    </dxc:ChartControl.Diagram>
                                    <dxc:ChartControl.Legend>
                                        <dxc:Legend
    HorizontalPosition="Right"
    ReverseItems="True" />
                                    </dxc:ChartControl.Legend>

                                    <!--<dxc:ChartControl.Titles>
                                        <dxc:Title
    Dock="Top"
    HorizontalAlignment="Center">통신 가용도 - UAV 2</dxc:Title>
                                    </dxc:ChartControl.Titles>-->

                                    <dxc:ChartControl.CrosshairOptions>
                                        <dxc:CrosshairOptions GroupHeaderPattern="Time : {A:yyyy-MM-dd HH:mm:ss.fff}"/>
                                    </dxc:ChartControl.CrosshairOptions>
                                </dxc:ChartControl>
                            </Grid>
                        </dxdo:DocumentPanel>

                        <dxdo:DocumentPanel Caption="UAV 3" Background="{StaticResource MLAH_COLOR_BG_Brush}" AllowClose="False">
                            <Grid>
                                <dxc:ChartControl Name="ScoreChart3" CrosshairEnabled="True" CustomDrawCrosshair="ScoreChart_CustomDrawCrosshair"
                                                  MouseLeftButtonDown="Chart_MouseLeftButtonDown3">
                                    <dxc:ChartControl.Diagram>
                                        <dxc:XYDiagram2D SeriesDataMember="AircraftID" EnableAxisXNavigation="True" EnableAxisYNavigation="False">
                                            <dxc:XYDiagram2D.AxisY>
                                                <dxc:AxisY2D>
                                                    <dxc:AxisY2D.Title>
                                                        <dxc:AxisTitle
                    Content="Connection" />
                                                    </dxc:AxisY2D.Title>

                                                    <dxc:AxisY2D.WholeRange>
                                                        <dxc:Range/>
                                                    </dxc:AxisY2D.WholeRange>

                                                    <dxc:AxisY2D.VisualRange>
                                                        <dxc:Range/>
                                                    </dxc:AxisY2D.VisualRange>
                                                </dxc:AxisY2D>
                                            </dxc:XYDiagram2D.AxisY>

                                            <dxc:XYDiagram2D.AxisX>
                                                <dxc:AxisX2D Visible="True" Alignment="Near" >
                                                    <dxc:AxisX2D.DateTimeScaleOptions>
                                                        <dxc:ContinuousDateTimeScaleOptions/>
                                                    </dxc:AxisX2D.DateTimeScaleOptions>
                                                    <dxc:AxisX2D.Label>
                                                        <dxc:AxisLabel TextPattern="{}{V:mm:ss.fff}"/>
                                                    </dxc:AxisX2D.Label>

                                                </dxc:AxisX2D>
                                            </dxc:XYDiagram2D.AxisX>

                                            <dxc:XYDiagram2D.SeriesTemplate>
                                                <dxc:LineSeries2D
                ArgumentDataMember="Timestamp"
                ArgumentScaleType="DateTime" 
                MarkerSize="10" 
                ValueDataMember="Status" ValueScaleType="Numerical" 
                CrosshairLabelPattern="UAV {S}: {V}" />
                                            </dxc:XYDiagram2D.SeriesTemplate>
                                        </dxc:XYDiagram2D>
                                    </dxc:ChartControl.Diagram>
                                    <dxc:ChartControl.Legend>
                                        <dxc:Legend
    HorizontalPosition="Right"
    ReverseItems="True" />
                                    </dxc:ChartControl.Legend>

                                    <!--<dxc:ChartControl.Titles>
                                        <dxc:Title
    Dock="Top"
    HorizontalAlignment="Center">통신 가용도 - UAV 3</dxc:Title>
                                    </dxc:ChartControl.Titles>-->

                                    <dxc:ChartControl.CrosshairOptions>
                                        <dxc:CrosshairOptions GroupHeaderPattern="Time : {A:yyyy-MM-dd HH:mm:ss.fff}"/>
                                    </dxc:ChartControl.CrosshairOptions>
                                </dxc:ChartControl>
                            </Grid>
                        </dxdo:DocumentPanel>

           

                   

                

                    </dxdo:DocumentGroup>
                    </dxdo:LayoutGroup >

            </dxdo:DockLayoutManager>
        </DockPanel>
    </Grid>
    

</UserControl>



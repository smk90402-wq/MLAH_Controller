<UserControl x:Class="MLAH_LogAnalyzer.View_Unit_Map_Target"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MLAH_LogAnalyzer"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:ViewModel_Unit_Map_Target, IsDesignTimeCreatable=True}"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:dxm="http://schemas.devexpress.com/winfx/2008/xaml/map"
        xmlns:core="clr-namespace:Microsoft.Xaml.Behaviors.Core;assembly=Microsoft.Xaml.Behaviors"
        Background="{StaticResource MLAH_COLOR_BG_Brush}" Loaded="UserControl_Loaded"
        PreviewKeyDown="UserControl_PreviewKeyDown">
    <!--<UserControl.DataContext>
        <Binding Source="{x:Static local:ViewModel_Unit_Map.SingletonInstance}"/>
    </UserControl.DataContext>-->
    <UserControl.Resources>
        <DataTemplate x:Key="ElementTemplate" DataType="{x:Type local:UnitMapObjectInfo}">
            <Grid>
                <Border MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" CacheMode="BitmapCache">
                <Image Source="{Binding imagesource}" Width="40" Height="40" MouseLeftButtonDown="Element_MouseLeftButtonDown">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform CenterX="20" CenterY="20">
                                <RotateTransform.Angle>
                                    <MultiBinding Converter="{StaticResource ConditionalRotationConverter }">
                                        <Binding Path="Heading" />
                                        <Binding Path="Type" />
                                    </MultiBinding>
                                </RotateTransform.Angle>
                            </RotateTransform>
                            <TranslateTransform X="-20" Y="-20" />
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
            </Border>
                <TextBlock Text="{Binding ID}"
                       Foreground="Black"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,20"  
                       Visibility="Visible"/>
            </Grid>
        </DataTemplate>

        <!-- 2. [신규] 표적(Target) 전용 템플릿 (상태 시각화 포함) -->
        <DataTemplate x:Key="TargetElementTemplate" DataType="{x:Type local:UnitMapObjectInfo}">
            <Grid>
                <Border Background="Transparent" Width="50" Height="50" 
                        MouseEnter="Element_MouseEnter" MouseLeave="Element_MouseLeave" 
                        MouseLeftButtonDown="Element_MouseLeftButtonDown"
                        RenderTransformOrigin="0.5, 0.5">
                    <Border.RenderTransform>
                        <TranslateTransform X="-25" Y="-25"/>
                    </Border.RenderTransform>
                </Border>

                <Image Source="{Binding imagesource}" Width="40" Height="40" 
                       RenderTransformOrigin="0.5, 0.5"
                       IsHitTestVisible="False">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Opacity" Value="1.0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="0">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="3">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>

                    <Image.RenderTransform>
                        <TransformGroup>
                            <RotateTransform>
                                <RotateTransform.Angle>
                                    <MultiBinding Converter="{StaticResource ConditionalRotationConverter}">
                                        <Binding Path="Heading" />
                                        <Binding Path="Type" />
                                    </MultiBinding>
                                </RotateTransform.Angle>
                            </RotateTransform>
                            <TranslateTransform X="-20" Y="-20" />
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <Border Width="44" Height="44"
                        BorderThickness="2" 
                        CornerRadius="4"
                        RenderTransformOrigin="0.5, 0.5"
                        IsHitTestVisible="False">
                    <Border.RenderTransform>
                        <TranslateTransform X="-20" Y="-20"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.5"/>
                    </Border.Effect>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="BorderBrush" Value="Black"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="BorderBrush" Value="OrangeRed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Path Data="M 0,0 L 30,30 M 0,30 L 30,0"
                      Stroke="Red" 
                      StrokeThickness="4"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      IsHitTestVisible="False">
                    <Path.RenderTransform>
                        <TranslateTransform X="-10" Y="-10"/>
                    </Path.RenderTransform>
                    <Path.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0"/>
                    </Path.Effect>

                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="3">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>

                <TextBlock Text="{Binding ID}"
                           Foreground="Black"
                           FontWeight="Bold"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,10"
                           IsHitTestVisible="False">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="White" BlurRadius="2" ShadowDepth="0" Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Grid>
        </DataTemplate>


        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>


    </UserControl.Resources>

    

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.ColumnSpan="2">
            <dxm:MapControl x:Name="mapControl" CenterPoint="{Binding CenterPoint, Mode=OneWay}" FlowDirection="LeftToRight" IsManipulationEnabled="True" EnableRotation="False"
                            MaxZoomLevel="15" MinZoomLevel="8"
                            MouseDown="MapControl_MouseButtonDown"
                            MouseMove="MapControl_MouseMove"
                            RenderOptions.BitmapScalingMode="LowQuality"

                            SizeChanged="mapControl_SizeChanged"
                            ZoomLevel="{Binding CurrentZoomLevel, Mode=TwoWay}"
                            UseSprings="False"
                            >
                <dxm:MapControl.Measurements>
                    <dxm:Measurements DistanceUnits="{x:Static dxm:MeasureUnit.Meter}" AreaUnits="{x:Static dxm:AreaMeasurementUnit.SquareMeter}">
                        <dxm:Measurements.ToolbarOptions>
                            <dxm:MeasurementToolbarOptions Visible="True" VerticalAlignment="Bottom"/>
                        </dxm:Measurements.ToolbarOptions>
                    </dxm:Measurements>
                </dxm:MapControl.Measurements>
                <dxm:MapControl.Layers>
                    <dxm:ImageLayer>

                        <dxm:ImageTileDataProvider>
                            <dxm:ImageTileDataProvider.TileSource>
                                <local:LocalTileSource/>
                            </dxm:ImageTileDataProvider.TileSource>
                        </dxm:ImageTileDataProvider>
                    </dxm:ImageLayer>



           

                    <dxm:VectorLayer x:Name="INITMissionPolygonLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionPolygonList, FallbackValue={x:Null}}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Fill="Blue" Stroke="Black" IsHitTestVisible="False" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points"/>-->
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                

                    <dxm:VectorLayer x:Name="INITMissionLineLayer" ShapeFill="CadetBlue" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False" AllowEditItems="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionLineList, FallbackValue={x:Null}}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings  Stroke="CadetBlue" IsHitTestVisible="False">
                                    <!--<dxm:MapPolylineSettings.StrokeStyle>
                                        <dxm:StrokeStyle 
                                            Thickness="3"        
                                            DashArray="4 2"
                                            DashCap="Round"
                                            StartLineCap="Round"
                                            EndLineCap="Round"
                                            LineJoin="Bevel"/>
                                    </dxm:MapPolylineSettings.StrokeStyle>-->
                                </dxm:MapPolylineSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapLineMappingInfo Point1="Point1" Point2="Point2"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="INITMissionLinePolygonLayer" ShapeFill="Blue" ShapeStroke="White" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionLinePolygonList, FallbackValue={x:Null}}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Stroke="Blue" IsHitTestVisible="False">
                                    <!--<dxm:MapLineSettings.StrokeStyle>
                                        <dxm:StrokeStyle 
                                            Thickness="3"        
                                            DashArray="4 2"
                                            DashCap="Round"
                                            StartLineCap="Round"
                                            EndLineCap="Round"
                                            LineJoin="Bevel"/>
                                    </dxm:MapLineSettings.StrokeStyle>-->
                                </dxm:MapPolygonSettings>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <!--<dxm:MapMultipointItemMappingInfo Points="Points" />-->
                                <dxm:MapMultipointItemMappingInfo Points="Coordinates"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>


                    <dxm:VectorLayer x:Name="INITMissionPointLayer"
                 EnableSelection="False"
                 EnableHighlighting="True"
                 ToolTipEnabled="False">
                        <dxm:VectorLayer.Data>
                            <dxm:ListSourceDataAdapter DataSource="{Binding INITMissionPointList, FallbackValue={x:Null}}">
                                <dxm:ListSourceDataAdapter.Mappings>
                                    <dxm:MapItemMappingInfo Latitude="Latitude" Longitude="Longitude"/>
                                </dxm:ListSourceDataAdapter.Mappings>
                                <dxm:ListSourceDataAdapter.ItemSettings>
                                    <dxm:MapCustomElementSettings>
                                        <dxm:MapCustomElementSettings.ContentTemplate>
                                            <DataTemplate>
                                                <Canvas Width="0" Height="0">
                                                    <!-- 점 중심을 맞추기 위해 -6, -6 -->
                                                    <Ellipse Width="12" Height="12"
                                         Fill="Blue"
                                         Stroke="White"
                                         StrokeThickness="1"
                                         Canvas.Left="-6"
                                         Canvas.Top="-6"/>

                                                    <!-- 텍스트는 점 아래에 8px 내려서 출력 -->
                                                    <TextBlock Text="{Binding TagString}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="Black"
                                           Width="60"
                                           TextAlignment="Center"
                                           Canvas.Left="-30"
                                           Canvas.Top="8"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"/>
                                                </Canvas>
                                            </DataTemplate>
                                        </dxm:MapCustomElementSettings.ContentTemplate>
                                    </dxm:MapCustomElementSettings>
                                </dxm:ListSourceDataAdapter.ItemSettings>
                            </dxm:ListSourceDataAdapter>
                        </dxm:VectorLayer.Data>
                    </dxm:VectorLayer>

          

                    <dxm:VectorLayer x:Name="MissionAreaLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding MissionAreas}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolygonSettings Fill="#33FFFF00" Stroke="Orange" IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Points"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="MissionLineLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding MissionDetailLines}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings Stroke="Cyan"  IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Points"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="TargetTracksLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding TargetTracks}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings Stroke="Red" IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Points"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <dxm:VectorLayer x:Name="EvaluationTrackLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding MissionTracks}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapPolylineSettings Stroke="Blue" IsHitTestVisible="False"/>
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapMultipointItemMappingInfo Points="Points"/>
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                

                    <dxm:VectorLayer x:Name="EvaluationUavPositionLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding EvaluationUavPositions}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings ContentTemplate="{StaticResource ElementTemplate}" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Location.Latitude" Longitude="Location.Longitude" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>

                    <!-- ✅ [핵심 수정 1] 표적 레이어에 새로운 템플릿(TargetElementTemplate) 적용 -->
                    <dxm:VectorLayer x:Name="EvaluationTargetLayer" EnableSelection="False" EnableHighlighting="False" ToolTipEnabled="False">
                        <dxm:ListSourceDataAdapter DataSource="{Binding EvaluationTargetPositions}">
                            <dxm:ListSourceDataAdapter.ItemSettings>
                                <dxm:MapCustomElementSettings ContentTemplate="{StaticResource TargetElementTemplate}" />
                            </dxm:ListSourceDataAdapter.ItemSettings>
                            <dxm:ListSourceDataAdapter.Mappings>
                                <dxm:MapItemMappingInfo Latitude="Location.Latitude" Longitude="Location.Longitude" />
                            </dxm:ListSourceDataAdapter.Mappings>
                        </dxm:ListSourceDataAdapter>
                    </dxm:VectorLayer>



                </dxm:MapControl.Layers>
                <dxm:MapControl.CoordinatesPanelOptions>
                    <dxm:CoordinatesPanelOptions Visible="False"/>
                </dxm:MapControl.CoordinatesPanelOptions>
                <dxm:MapControl.ScalePanelOptions>
                    <dxm:ScalePanelOptions ShowMilesScale="False"/>
                </dxm:MapControl.ScalePanelOptions>
                <dxm:MapControl.ScrollButtonsOptions>
                    <dxm:ScrollButtonsOptions Visible="False"/>
                </dxm:MapControl.ScrollButtonsOptions>
                <dxm:MapControl.ZoomTrackbarOptions>
                    <dxm:ZoomTrackbarOptions HorizontalAlignment="Right"/>
                </dxm:MapControl.ZoomTrackbarOptions>

                
            </dxm:MapControl>

     
        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="20"/>
                <!--<ColumnDefinition Width="40"/>
                <ColumnDefinition Width="60"/>-->
            </Grid.ColumnDefinitions>


            <TextBlock Grid.Column="1" Text="위도 : " Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <TextBlock Grid.Column="2" x:Name="MapLat" Text="{Binding MapCursorLat, StringFormat=F5}"  Background="{StaticResource DefaultBg_Brush}" Height="20" Style="{StaticResource NormalTextBlock}"/>
            <TextBlock Grid.Column="3" Text="°" Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>

            <TextBlock Grid.Column="4" Text="경도 : " Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <TextBlock Grid.Column="5" x:Name="MapLon" Text="{Binding MapCursorLon, StringFormat=F5}"  Background="{StaticResource DefaultBg_Brush}" Height="20" Style="{StaticResource NormalTextBlock}"/>
            <TextBlock Grid.Column="6" Text="°" Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <!--<TextBlock Grid.Column="5" Text="고도 : " Foreground="White" Background="{StaticResource DefaultBg_Brush}" Height="20"/>
            <TextBlock Grid.Column="6" x:Name="MapAlt" Text="TBD"  Background="{StaticResource DefaultBg_Brush}" Height="20" Style="{StaticResource NormalTextBlock}"/>-->
        </Grid>

    </Grid>
    


</UserControl>

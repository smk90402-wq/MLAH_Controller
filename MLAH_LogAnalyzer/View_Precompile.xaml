<UserControl x:Class="MLAH_LogAnalyzer.View_Precompile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MLAH_LogAnalyzer"
             mc:Ignorable="d" 
             Background="{StaticResource MLAH_COLOR_BG_Brush}"  
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             d:DataContext="{d:DesignInstance Type=local:View_Precompile, IsDesignTimeCreatable=True}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Header="데이터 로드" Foreground="White" Grid.Row="0">
                <StackPanel Margin="5">
                    <Button Content="로그 루트 폴더 선택" Height="30" Click="Button_PreviewMouseDown"/>
                    <TextBlock Text="{Binding SelectedRootPath}" Foreground="Gray" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- 헬기 위치: 0401 우선, null이면 RealLAHData 보충 / LOS 등 부가 필드: RealLAHData에서 항상 병합 -->

            <GroupBox Header="시나리오 매칭 결과" Foreground="White" Grid.Row="2" Margin="0,10,0,0">
                <!--<DataGrid ItemsSource="{Binding MatchedScenarios}" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True" Background="#2D2D30">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Raw 폴더 (시간)" Binding="{Binding RawFolderName}" Width="*"/>
                        <DataGridTextColumn Header="Target 폴더" Binding="{Binding TargetFolderName}" Width="*"/>
                        <DataGridTextColumn Header="오차(초)" Binding="{Binding TimeDiffSec, StringFormat=F1}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>-->

                <dxg:GridControl
 
x:Name="InputMissionGrid"
dx:ThemeManager.ThemeName="VS2019Dark"
ItemsSource="{Binding MatchedScenarios}"
AutoGenerateColumns="None"
Height="295"
VerticalAlignment="Top"
Grid.Row="1"
Grid.Column="1">

                    <dxg:GridControl.View>
                        <dxg:TableView
        ShowGroupPanel="False"
        AllowResizing="False"
        HorizontalScrollbarVisibility="Hidden"
        AllowEditing="True"
        AllowColumnFiltering="False"
        AllowColumnMoving="False"
        AllowSorting="False"
        NavigationStyle="Cell"
                    EditorShowMode="MouseDown"
                    EnableImmediatePosting="True"
                    >
                            <dxg:TableView.FormatConditions>
                                <dxg:FormatCondition Expression="[IsAlreadyGenerated] == True" ApplyToRow="True">
                                    <dxg:FormatCondition.Format>
                                        <dx:Format Background="#550000" Foreground="#FFAAAA"/>
                                    </dxg:FormatCondition.Format>
                                </dxg:FormatCondition>
                            </dxg:TableView.FormatConditions>
                        </dxg:TableView>
                    </dxg:GridControl.View>

                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="RawFolderName" Header="Log Source" Width="2*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>

                        <dxg:GridColumn FieldName="TargetFolderName" Header="Target Log Source" Width="2*" HorizontalHeaderContentAlignment="Center" ReadOnly="True"/>
                        <dxg:GridColumn FieldName="ExistingFileName" Header="기존 시나리오 파일" Width="2*" HorizontalHeaderContentAlignment="Center">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="TimeDiffSec" Header="오차 (초)" Width="*" HorizontalHeaderContentAlignment="Center" ReadOnly="True">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings HorizontalContentAlignment="Center"/>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>



                </dxg:GridControl>
            </GroupBox>

            <Button Grid.Row="3" Content="데이터 변환 시작 (Start Generation)" Height="40" Margin="0,10,0,0"
                    Command="{Binding GenerateCommand}" 
                    IsEnabled="{Binding IsGenerationEnabled}"
                    Background="DarkOrange" Foreground="White" FontWeight="Bold"/>
        </Grid>

        <GroupBox Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Header="처리 로그 (Log)" Foreground="White" Margin="10">
            <TextBox Text="{Binding LogText}" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                     Background="#1E1E1E" Foreground="LightGreen" FontFamily="Consolas"
                     TextChanged="TextBox_TextChanged"/>
        </GroupBox>
    </Grid>
</UserControl>
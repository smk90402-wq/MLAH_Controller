<dx:ThemedWindow x:Class="MLAH_LogAnalyzer.SimpleProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        dx:ThemeManager.ThemeName="VS2019Dark" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Loading" Height="130" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Border Background="#FF3C3C3C" CornerRadius="5" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Loading Scenarios..." 
                       FontSize="16" 
                       FontWeight="SemiBold"
                       Foreground="White"/>

            <ProgressBar x:Name="progressBar" Grid.Row="1" 
                         Minimum="0" Maximum="100" 
                         VerticalAlignment="Center" 
                         Height="20"
                         Margin="0,10"/>

            <TextBlock x:Name="statusText" Grid.Row="2" 
                       Text="Initializing..." 
                       Foreground="Gray"
                       HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</dx:ThemedWindow>